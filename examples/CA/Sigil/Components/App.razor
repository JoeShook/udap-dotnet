<!DOCTYPE html>
<html lang="en" style="background-color: #1a1a2e; color-scheme: dark;">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sigil - PKI Management</title>
    <base href="/" />
    <style>
        html, body { height: 100%; margin: 0; background-color: #1a1a2e; color: #e0e0e0; }
    </style>
    <link rel="stylesheet" href="/css/site.css" />
    <link href="/_content/Microsoft.FluentUI.AspNetCore.Components/css/reboot.css" rel="stylesheet" />
    <link href="/Sigil.styles.css" rel="stylesheet" />
    <HeadOutlet @rendermode="InteractiveServer" />
</head>
<body>
    <Routes @rendermode="InteractiveServer" />
    <script src="/_framework/blazor.web.js"></script>
    <script>
        window.sigilFolderUpload = function(inputId) {
            var input = document.getElementById(inputId);
            if (input) {
                input.setAttribute('webkitdirectory', '');
                input.setAttribute('directory', '');
                input.click();
            }
        };

        window.sigilColResize = function(table) {
            if (!table) return;
            var cols = table.querySelectorAll('col');
            var handles = table.querySelectorAll('.col-resize');
            handles.forEach(function(handle, i) {
                handle.addEventListener('mousedown', function(e) {
                    e.preventDefault();
                    var startX = e.pageX;
                    var startW = cols[i].offsetWidth || parseInt(getComputedStyle(cols[i]).width);
                    function onMove(ev) {
                        var newW = Math.max(40, startW + ev.pageX - startX);
                        cols[i].style.width = newW + 'px';
                    }
                    function onUp() {
                        document.removeEventListener('mousemove', onMove);
                        document.removeEventListener('mouseup', onUp);
                    }
                    document.addEventListener('mousemove', onMove);
                    document.addEventListener('mouseup', onUp);
                });
            });
        };
    </script>
</body>
</html>
