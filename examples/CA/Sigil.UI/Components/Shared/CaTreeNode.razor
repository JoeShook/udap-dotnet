@using Sigil.Common.ViewModels

<FluentTreeItem Text="@Node.Name"
                @key="@($"ca-{Node.Id}")"
                Id="@($"tree-{Node.Thumbprint}")"
                Data="@Node"
                InitiallyExpanded="true"
                Style="@(IsError(Node.Status) ? $"color: {NodeColor(Node.Status)};" : "")">
    <span slot="start" style="display: flex; align-items: center; gap: 0.35rem;">
        @if (Node.CertificateRole == "RootCA")
        {
            <FluentIcon Value="@(new Icons.Regular.Size16.ShieldKeyhole())" Color="Color.Custom"
                        CustomColor="@(IsError(Node.Status) ? NodeColor(Node.Status) : "#2d6a4f")" />
        }
        else
        {
            <FluentIcon Value="@(new Icons.Regular.Size16.Shield())" Color="Color.Custom"
                        CustomColor="@(IsError(Node.Status) ? NodeColor(Node.Status) : "#1976d2")" />
        }
        <CertBadge Status="@Node.Status" />
    </span>

    @* Recursive: sub-CA nodes *@
    @foreach (var subCa in Node.Children.Where(c => c.CertificateRole is "IntermediateCA" or "RootCA"))
    {
        <CaTreeNode Node="@subCa" />
    }

    @* End-entity certs *@
    @foreach (var issued in Node.Children.Where(c => c.CertificateRole == "EndEntity"))
    {
        <FluentTreeItem Text="@issued.Name"
                        @key="@($"ee-{issued.Id}")"
                        Id="@($"tree-{issued.Thumbprint}")"
                        Data="@issued"
                        Style="@(IsError(issued.Status) ? $"color: {NodeColor(issued.Status)};" : "")">
            <span slot="start" style="display: flex; align-items: center; gap: 0.35rem;">
                <FluentIcon Value="@(new Icons.Regular.Size16.Certificate())" Color="Color.Custom"
                            CustomColor="@(IsError(issued.Status) ? NodeColor(issued.Status) : "")"
                            Style="@(IsError(issued.Status) ? "" : "opacity: 0.7;")" />
                <CertBadge Status="@issued.Status" />
            </span>
        </FluentTreeItem>
    }

    @* CRL nodes *@
    @foreach (var crl in Node.Children.Where(c => c.CertificateRole == "CRL"))
    {
        <FluentTreeItem Text="@crl.Name"
                        @key="@($"crl-{crl.Id}")"
                        Data="@crl"
                        Style="@(IsError(crl.Status) ? $"color: {NodeColor(crl.Status)};" : "font-style: italic; opacity: 0.8;")">
            <span slot="start" style="display: flex; align-items: center; gap: 0.35rem;">
                <FluentIcon Value="@(new Icons.Regular.Size16.DocumentBulletList())" Color="Color.Custom"
                            CustomColor="@(IsError(crl.Status) ? NodeColor(crl.Status) : "")"
                            Style="@(IsError(crl.Status) ? "" : "opacity: 0.6;")" />
                <CrlBadge Status="@(crl.Status == CertificateStatus.Expired ? CrlTimeStatus.Expired : crl.Status == CertificateStatus.Expiring ? CrlTimeStatus.ExpiringSoon : CrlTimeStatus.Valid)" />
            </span>
        </FluentTreeItem>
    }
</FluentTreeItem>

@code {
    [Parameter, EditorRequired] public CertificateChainNodeViewModel Node { get; set; } = default!;

    private static bool IsError(CertificateStatus status) =>
        status is CertificateStatus.Expired or CertificateStatus.Revoked or CertificateStatus.Untrusted;

    private static string NodeColor(CertificateStatus status) => status switch
    {
        CertificateStatus.Expired => "#e94560",
        CertificateStatus.Revoked => "#9c27b0",
        CertificateStatus.Untrusted => "#ff9800",
        _ => ""
    };
}
