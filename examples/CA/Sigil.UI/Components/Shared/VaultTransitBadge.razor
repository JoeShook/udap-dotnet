@using Sigil.Common.ViewModels

@if (Node.KeyStorage == "vault-transit")
{
    @if (Node.RemoteKeyMissing == true)
    {
        <span slot="end" title="Vault Transit key is MISSING — re-create this certificate">
            <FluentIcon Value="@(new Icons.Regular.Size16.Warning())" Color="Color.Custom" CustomColor="#e94560" />
        </span>
    }
    else
    {
        <span slot="end" title="Vault Transit">
            <FluentIcon Value="@(new Icons.Regular.Size16.LockShield())" Color="Color.Custom" CustomColor="#1565c0" />
        </span>
    }
}

@code {
    [Parameter, EditorRequired] public CertificateChainNodeViewModel Node { get; set; } = default!;
}
