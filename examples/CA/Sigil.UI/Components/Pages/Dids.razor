@page "/dids"
@using Sigil.Did.ViewModels

<PageTitle>Sigil - DIDs</PageTitle>

<FluentLabel Typo="Typography.PageTitle">DIDs</FluentLabel>

<FluentCard Style="margin-top: 1rem;">
    <FluentStack Orientation="Orientation.Horizontal" Style="align-items: center; gap: 0.5rem;">
        <FluentLabel Typo="Typography.Subject">Decentralized Identifiers minted in Sigil</FluentLabel>
        <FluentSpacer />
        <FluentButton Appearance="Appearance.Accent" OnClick="ShowMintDialog"
                      IconStart="@(new Icons.Regular.Size16.Add())">
            Mint DID
        </FluentButton>
    </FluentStack>

    <FluentDataGrid Items="@dids.AsQueryable()" Style="margin-top: 0.5rem;" ResizableColumns="true"
                    GridTemplateColumns="minmax(180px, 1fr) 70px minmax(360px, 3fr) minmax(140px, 1fr) 150px 90px auto">
        <PropertyColumn Property="@(d => d.TrustDomainName)" Title="Trust Domain" Sortable="true" Class="multiline-text" />
        <PropertyColumn Property="@(d => d.Method)" Title="Method" />
        <TemplateColumn Title="DID" Class="multiline-text">
            <code style="font-size: 12px;">@context.Did</code>
        </TemplateColumn>
        <PropertyColumn Property="@(d => d.TemplateName)" Title="Template" Class="multiline-text" />
        <PropertyColumn Property="@(d => d.CreatedAt)" Title="Created" Format="yyyy-MM-dd HH:mm" />
        <TemplateColumn Title="Status">
            @if (context.Deactivated)
            {
                <FluentBadge Appearance="Appearance.Neutral">deactivated</FluentBadge>
            }
            else
            {
                <FluentBadge Appearance="Appearance.Accent">active</FluentBadge>
            }
        </TemplateColumn>
        <TemplateColumn Title="Actions">
            <FluentStack Orientation="Orientation.Horizontal" Wrap="true" Style="gap: 0.25rem;">
                <FluentButton Size="ButtonSize.Small" Appearance="Appearance.Outline"
                              IconStart="@(new Icons.Regular.Size16.Eye())"
                              OnClick="@(() => ShowDetail(context))">
                    View
                </FluentButton>
                @if (!context.Deactivated)
                {
                    <FluentButton Size="ButtonSize.Small" Appearance="Appearance.Outline"
                                  IconStart="@(new Icons.Regular.Size16.PlugDisconnected())"
                                  OnClick="@(() => DeactivateAsync(context))">
                        Deactivate
                    </FluentButton>
                }
            </FluentStack>
        </TemplateColumn>
    </FluentDataGrid>
</FluentCard>

<FluentDialog @bind-Hidden="@mintDialogHidden" Modal="true" TrapFocus="true"
              Style="min-width: 600px; max-height: 80vh; overflow: auto;">
    <FluentDialogHeader>Mint DID</FluentDialogHeader>
    <FluentDialogBody>
        <FluentSelect TOption="TrustDomainOption" Items="@trustDomainOptions"
                      OptionValue="@(o => o.Id.ToString())"
                      OptionText="@(o => o.Name)"
                      @bind-SelectedOption="selectedTrustDomain"
                      Label="Trust Domain" Style="width: 100%;" />
        <FluentSelect TOption="DidTemplateOption" Items="@didTemplateOptions"
                      OptionValue="@(o => o.Id.ToString())"
                      OptionText="@(o => o.Label)"
                      @bind-SelectedOption="selectedDidTemplate"
                      Label="DID Template" Style="width: 100%; margin-top: 0.5rem;" />

        @if (!string.IsNullOrEmpty(mintError))
        {
            <FluentMessageBar Intent="MessageIntent.Error" AllowDismiss="false" Style="margin-top: 0.5rem;">
                @mintError
            </FluentMessageBar>
        }

        @if (lastMintResult != null)
        {
            <FluentLabel Typo="Typography.Subject" Style="margin-top: 0.75rem;">Synthesized DID Document</FluentLabel>
            <pre style="background: #1e1e1e; color: #d4d4d4; padding: 0.75rem; max-height: 320px; overflow: auto; font-size: 12px; border-radius: 4px;">@lastMintResult.DidDocumentJson</pre>
        }
    </FluentDialogBody>
    <FluentDialogFooter>
        <FluentButton Appearance="Appearance.Accent" OnClick="MintAsync"
                      Disabled="@(selectedTrustDomain == null || selectedDidTemplate == null)">
            Mint
        </FluentButton>
        <FluentButton Appearance="Appearance.Outline" OnClick="@(() => mintDialogHidden = true)">
            Close
        </FluentButton>
    </FluentDialogFooter>
</FluentDialog>

<FluentDialog @bind-Hidden="@detailDialogHidden" Modal="true" TrapFocus="true"
              Style="min-width: 800px; max-height: 85vh; overflow: auto;">
    <FluentDialogHeader>DID Document</FluentDialogHeader>
    <FluentDialogBody>
        @if (selectedDetail != null)
        {
            <FluentLabel Typo="Typography.Body"><strong>@selectedDetail.Did</strong></FluentLabel>
            <pre style="background: #1e1e1e; color: #d4d4d4; padding: 0.75rem; max-height: 480px; overflow: auto; font-size: 12px; border-radius: 4px; margin-top: 0.5rem;">@selectedDetail.SynthesizedDocumentJson</pre>

            <FluentLabel Typo="Typography.Subject" Style="margin-top: 0.75rem;">Verification Methods</FluentLabel>
            @foreach (var vm in selectedDetail.VerificationMethods)
            {
                <div style="border: 1px solid var(--neutral-stroke-rest); padding: 0.5rem; margin-top: 0.25rem; border-radius: 4px;">
                    <div style="font-size: 11px;"><code>@vm.MethodId</code></div>
                    <div style="font-size: 11px; margin-top: 0.25rem;">Algorithm: <strong>@vm.KeyAlgorithm</strong> · Purposes: <strong>@vm.Purposes</strong></div>
                    <div style="font-size: 11px; margin-top: 0.25rem;">Public key (multibase): <code>@vm.PublicKeyMultibase</code></div>
                </div>
            }
        }
    </FluentDialogBody>
    <FluentDialogFooter>
        <FluentButton Appearance="Appearance.Outline" OnClick="@(() => detailDialogHidden = true)">
            Close
        </FluentButton>
    </FluentDialogFooter>
</FluentDialog>
