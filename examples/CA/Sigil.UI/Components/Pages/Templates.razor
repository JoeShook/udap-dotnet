@page "/templates"
@using System.Security.Cryptography.X509Certificates

<PageTitle>Sigil - Templates</PageTitle>

<FluentLabel Typo="Typography.PageTitle">Certificate Templates</FluentLabel>

<FluentCard Style="margin-top: 1rem;">
    <FluentStack Orientation="Orientation.Horizontal" Style="align-items: center; gap: 0.5rem;">
        <FluentLabel Typo="Typography.Subject">Templates</FluentLabel>
        <FluentSpacer />
        <FluentButton Appearance="Appearance.Accent" OnClick="ShowAddDialog"
                      IconStart="@(new Icons.Regular.Size16.Add())">
            Add Template
        </FluentButton>
    </FluentStack>

    <FluentDataGrid Items="@templates.AsQueryable()" Style="margin-top: 0.5rem;">
        <PropertyColumn Property="@(t => t.Name)" Title="Name" Sortable="true" IsDefaultSortColumn="true" />
        <TemplateColumn Title="Type">
            @{
                var (bg, label) = GetTypeBadge(context.CertificateType);
            }
            <FluentBadge BackgroundColor="@bg" Color="white" Style="font-size: 0.75rem;">@label</FluentBadge>
        </TemplateColumn>
        <PropertyColumn Property="@(t => t.KeyAlgorithm)" Title="Algorithm" />
        <TemplateColumn Title="Key Size">
            @if (context.KeyAlgorithm == "ECDSA")
            {
                <span>@(context.EcdsaCurve ?? "P-384")</span>
            }
            else
            {
                <span>@context.KeySize</span>
            }
        </TemplateColumn>
        <PropertyColumn Property="@(t => t.ValidityDays)" Title="Validity (days)" />
        <TemplateColumn Title="Preset">
            @if (context.IsPreset)
            {
                <FluentBadge BackgroundColor="#2d6a4f" Color="white" Style="font-size: 0.7rem;">Preset</FluentBadge>
            }
        </TemplateColumn>
        <TemplateColumn Title="Actions">
            <FluentButton Size="ButtonSize.Small" Appearance="Appearance.Outline"
                          IconStart="@(new Icons.Regular.Size16.Edit())"
                          OnClick="@(() => ShowEditDialog(context))">
                Edit
            </FluentButton>
            <FluentButton Size="ButtonSize.Small" Appearance="Appearance.Outline"
                          IconStart="@(new Icons.Regular.Size16.Copy())"
                          OnClick="@(() => CloneTemplateAsync(context))">
                Clone
            </FluentButton>
            @if (!context.IsPreset)
            {
                <FluentButton Size="ButtonSize.Small" Appearance="Appearance.Outline"
                              IconStart="@(new Icons.Regular.Size16.Delete())"
                              OnClick="@(() => DeleteTemplateAsync(context))">
                    Delete
                </FluentButton>
            }
        </TemplateColumn>
    </FluentDataGrid>
</FluentCard>

@* Add/Edit Dialog *@
<FluentDialog @bind-Hidden="@dialogHidden" Modal="true" TrapFocus="true"
              Style="min-width: 600px; max-height: 80vh; overflow-y: auto;">
    <FluentDialogHeader>@(isEditing ? "Edit Template" : "Add Template")</FluentDialogHeader>
    <FluentDialogBody>
        <div style="display: flex; flex-direction: column; gap: 0.75rem;">

            @* General *@
            <FluentLabel Typo="Typography.Subject" Style="margin-top: 0.25rem;">General</FluentLabel>
            <FluentTextField @bind-Value="editName" Label="Name" Style="width: 100%;" />
            <FluentTextField @bind-Value="editDescription" Label="Description" Style="width: 100%;" />
            <FluentSelect TOption="CertificateType" @bind-SelectedOption="editCertType" Label="Certificate Type"
                          Items="@certTypes" OptionText="@(ct => GetCertTypeLabel(ct))"
                          Style="width: 100%;" />
            <FluentNumberField @bind-Value="editValidityDays" Label="Validity (days)" Min="1" Style="width: 100%;" />

            @* Key Parameters *@
            <FluentLabel Typo="Typography.Subject" Style="margin-top: 0.5rem;">Key Parameters</FluentLabel>
            <FluentSelect TOption="string" @bind-SelectedOption="editKeyAlgorithm" Label="Key Algorithm"
                          Items="@keyAlgorithms" Style="width: 100%;" />
            @if (editKeyAlgorithm == "RSA")
            {
                <FluentSelect TOption="int" @bind-SelectedOption="editKeySize" Label="Key Size (bits)"
                              Items="@rsaKeySizes" OptionText="@(s => s.ToString())"
                              Style="width: 100%;" />
            }
            else
            {
                <FluentSelect TOption="string" @bind-SelectedOption="editEcdsaCurve" Label="ECDSA Curve"
                              Items="@ecdsaCurves" Style="width: 100%;" />
            }
            <FluentSelect TOption="string" @bind-SelectedOption="editHashAlgorithm" Label="Hash Algorithm"
                          Items="@hashAlgorithms" Style="width: 100%;" />

            @* Extensions *@
            <FluentLabel Typo="Typography.Subject" Style="margin-top: 0.5rem;">Extensions</FluentLabel>

            <FluentLabel>Key Usage</FluentLabel>
            <div style="display: flex; flex-wrap: wrap; gap: 0.5rem;">
                @foreach (var ku in keyUsageOptions)
                {
                    var flag = ku.Flag;
                    <FluentCheckbox Label="@ku.Label"
                                    Value="@((editKeyUsageFlags & (int)flag) != 0)"
                                    ValueChanged="@(v => ToggleKeyUsageFlag(flag, v))" />
                }
            </div>
            <FluentCheckbox @bind-Value="editIsKeyUsageCritical" Label="Key Usage is Critical" />

            <FluentLabel>Extended Key Usage</FluentLabel>
            <div style="display: flex; flex-wrap: wrap; gap: 0.5rem;">
                @foreach (var eku in ekuOptions)
                {
                    var oid = eku.Oid;
                    <FluentCheckbox Label="@($"{eku.Name} ({eku.Oid})")"
                                    Value="@IsEkuSelected(oid)"
                                    ValueChanged="@(v => ToggleEku(oid, v))" />
                }
            </div>
            <FluentTextField Value="@editCustomEkuOids"
                             ValueChanged="@(v => { editCustomEkuOids = v; SyncEkuOids(); })"
                             Label="Additional OIDs (semicolon-delimited)" Style="width: 100%;"
                             Placeholder="1.3.6.1.5.5.7.3.9" />
            @if (!string.IsNullOrWhiteSpace(editEkuOids))
            {
                <div style="font-size: 0.8rem; opacity: 0.6; margin-top: -0.25rem;">
                    Selected: <code>@editEkuOids</code>
                </div>
            }
            <FluentCheckbox @bind-Value="editIsEkuCritical" Label="EKU is Critical" />

            <div style="display: flex; gap: 1rem; align-items: center;">
                <FluentCheckbox @bind-Value="editIsBasicConstraintsCa" Label="Basic Constraints: CA" />
                <FluentCheckbox @bind-Value="editIsBasicConstraintsCritical" Label="Critical" />
            </div>
            @if (editIsBasicConstraintsCa)
            {
                <FluentNumberField @bind-Value="editPathLengthConstraint" Label="Path Length Constraint (leave empty for unlimited)"
                                   Min="0" Style="width: 100%;" />
            }

            <FluentTextField @bind-Value="editSubjectTemplate" Label="Subject DN Template"
                             Placeholder="CN={Name}, O={Org}, C=US" Style="width: 100%;" />

            @* Distribution *@
            <FluentLabel Typo="Typography.Subject" Style="margin-top: 0.5rem;">Distribution</FluentLabel>
            <FluentCheckbox @bind-Value="editIncludeCdp" Label="Include CRL Distribution Point" />
            @if (editIncludeCdp)
            {
                <FluentTextField @bind-Value="editCdpUrlTemplate" Label="CDP URL Template"
                                 Placeholder="http://crl.example.com/{CAName}.crl" Style="width: 100%;" />
            }
            <FluentCheckbox @bind-Value="editIncludeAia" Label="Include Authority Information Access" />
            @if (editIncludeAia)
            {
                <FluentTextField @bind-Value="editAiaUrlTemplate" Label="AIA URL Template"
                                 Placeholder="http://crl.example.com/{CAName}.cer" Style="width: 100%;" />
            }

            @* SAN Types *@
            <FluentLabel Typo="Typography.Subject" Style="margin-top: 0.5rem;">Subject Alternative Name Types</FluentLabel>
            <div style="display: flex; gap: 1rem;">
                <FluentCheckbox @bind-Value="editSanUri" Label="URI" />
                <FluentCheckbox @bind-Value="editSanDns" Label="DNS" />
                <FluentCheckbox @bind-Value="editSanEmail" Label="Email" />
                <FluentCheckbox @bind-Value="editSanIp" Label="IP" />
            </div>
        </div>
    </FluentDialogBody>
    <FluentDialogFooter>
        <FluentButton Appearance="Appearance.Accent" OnClick="SaveTemplateAsync"
                      Disabled="@(string.IsNullOrWhiteSpace(editName))">
            @(isEditing ? "Save" : "Create")
        </FluentButton>
        <FluentButton Appearance="Appearance.Outline" OnClick="@(() => dialogHidden = true)">
            Cancel
        </FluentButton>
    </FluentDialogFooter>
</FluentDialog>
