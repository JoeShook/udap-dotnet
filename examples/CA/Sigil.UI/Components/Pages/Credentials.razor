@page "/credentials"
@using Sigil.Vc.ViewModels

<PageTitle>Sigil - Credentials</PageTitle>

<FluentLabel Typo="Typography.PageTitle">Issued Credentials</FluentLabel>

<FluentCard Style="margin-top: 1rem;">
    <FluentStack Orientation="Orientation.Horizontal" Style="align-items: center; gap: 0.5rem;">
        <FluentLabel Typo="Typography.Subject">Verifiable Credentials issued from this Sigil instance</FluentLabel>
        <FluentSpacer />
        <FluentButton Appearance="Appearance.Accent" OnClick="ShowIssueDialog"
                      IconStart="@(new Icons.Regular.Size16.Add())">
            Issue Credential
        </FluentButton>
    </FluentStack>

    <FluentDataGrid Items="@credentials.AsQueryable()" Style="margin-top: 0.5rem;" ResizableColumns="true"
                    GridTemplateColumns="minmax(150px, 1fr) minmax(160px, 1fr) minmax(260px, 2fr) minmax(260px, 2fr) 90px 150px 90px auto">
        <PropertyColumn Property="@(c => c.TrustDomainName)" Title="Trust Domain" Sortable="true" Class="multiline-text" />
        <PropertyColumn Property="@(c => c.SchemaName)" Title="Schema" Class="multiline-text" />
        <TemplateColumn Title="Issuer DID" Class="multiline-text">
            <code style="font-size: 11px;">@context.IssuerDid</code>
        </TemplateColumn>
        <TemplateColumn Title="Subject DID" Class="multiline-text">
            <code style="font-size: 11px;">@context.SubjectDid</code>
        </TemplateColumn>
        <PropertyColumn Property="@(c => c.Format)" Title="Format" />
        <PropertyColumn Property="@(c => c.IssuedAt)" Title="Issued" Format="yyyy-MM-dd HH:mm" />
        <TemplateColumn Title="Status">
            @if (context.Revoked)
            {
                <FluentBadge Appearance="Appearance.Neutral">revoked</FluentBadge>
            }
            else
            {
                <FluentBadge Appearance="Appearance.Accent">valid</FluentBadge>
            }
        </TemplateColumn>
        <TemplateColumn Title="Actions">
            <FluentStack Orientation="Orientation.Horizontal" Wrap="true" Style="gap: 0.25rem;">
                <FluentButton Size="ButtonSize.Small" Appearance="Appearance.Outline"
                              IconStart="@(new Icons.Regular.Size16.Eye())"
                              OnClick="@(() => ShowDetail(context))">
                    View
                </FluentButton>
                @if (!context.Revoked)
                {
                    <FluentButton Size="ButtonSize.Small" Appearance="Appearance.Outline"
                                  IconStart="@(new Icons.Regular.Size16.Delete())"
                                  OnClick="@(() => RevokeAsync(context))">
                        Revoke
                    </FluentButton>
                }
            </FluentStack>
        </TemplateColumn>
    </FluentDataGrid>
</FluentCard>

<FluentDialog @bind-Hidden="@issueDialogHidden" Modal="true" TrapFocus="true"
              Style="min-width: 720px; max-height: 85vh; overflow: auto;">
    <FluentDialogHeader>Issue Credential</FluentDialogHeader>
    <FluentDialogBody>
        <FluentSelect TOption="TrustDomainOption" Items="@trustDomainOptions"
                      OptionValue="@(o => o.Id.ToString())" OptionText="@(o => o.Name)"
                      @bind-SelectedOption="selectedTrustDomain"
                      Label="Trust Domain" Style="width: 100%;" />

        <FluentSelect TOption="SchemaOption" Items="@schemaOptions"
                      OptionValue="@(o => o.Id.ToString())" OptionText="@(o => o.Label)"
                      @bind-SelectedOption="selectedSchema"
                      Label="Credential Schema" Style="width: 100%; margin-top: 0.5rem;" />

        <FluentSelect TOption="DidOption" Items="@issuerOptions"
                      OptionValue="@(o => o.Id.ToString())" OptionText="@(o => o.Label)"
                      @bind-SelectedOption="selectedIssuer"
                      Label="Issuer DID" Style="width: 100%; margin-top: 0.5rem;" />

        <FluentTextField @bind-Value="subjectDid" Label="Subject DID"
                         Placeholder="did:key:z6Mk..."
                         Style="width: 100%; margin-top: 0.5rem;" />

        <FluentLabel Typo="Typography.Subject" Style="margin-top: 0.75rem;">Claims JSON</FluentLabel>
        <FluentTextArea @bind-Value="claimsJson"
                        Style="width: 100%; min-height: 180px; font-family: monospace; font-size: 12px;"
                        Placeholder='{ "name": "Joe", "role": "engineer" }' />

        @if (!string.IsNullOrEmpty(issueError))
        {
            <FluentMessageBar Intent="MessageIntent.Error" AllowDismiss="false" Style="margin-top: 0.5rem;">
                @issueError
            </FluentMessageBar>
        }

        @if (lastIssueResult != null)
        {
            <FluentLabel Typo="Typography.Subject" Style="margin-top: 0.75rem;">Issued Credential (JWT-VC)</FluentLabel>
            <pre style="background: #1e1e1e; color: #d4d4d4; padding: 0.75rem; max-height: 200px; overflow: auto; font-size: 11px; border-radius: 4px; word-break: break-all; white-space: pre-wrap;">@lastIssueResult.SignedCredential</pre>
        }
    </FluentDialogBody>
    <FluentDialogFooter>
        <FluentButton Appearance="Appearance.Accent" OnClick="IssueAsync"
                      Disabled="@(!CanIssue())">
            Issue
        </FluentButton>
        <FluentButton Appearance="Appearance.Outline" OnClick="@(() => issueDialogHidden = true)">
            Close
        </FluentButton>
    </FluentDialogFooter>
</FluentDialog>

<FluentDialog @bind-Hidden="@detailDialogHidden" Modal="true" TrapFocus="true"
              Style="min-width: 900px; max-height: 90vh; overflow: auto;">
    <FluentDialogHeader>Credential Detail</FluentDialogHeader>
    <FluentDialogBody>
        @if (selectedDetail != null)
        {
            <div style="font-size: 12px;">
                <strong>Credential ID:</strong> <code>@selectedDetail.CredentialId</code><br />
                <strong>Issuer:</strong> <code>@selectedDetail.IssuerDid</code><br />
                <strong>Subject:</strong> <code>@selectedDetail.SubjectDid</code>
            </div>

            <FluentLabel Typo="Typography.Subject" Style="margin-top: 0.75rem;">Header</FluentLabel>
            <pre style="background: #1e1e1e; color: #d4d4d4; padding: 0.5rem; font-size: 12px; border-radius: 4px;">@selectedDetail.DecodedHeaderJson</pre>

            <FluentLabel Typo="Typography.Subject" Style="margin-top: 0.5rem;">Payload</FluentLabel>
            <pre style="background: #1e1e1e; color: #d4d4d4; padding: 0.5rem; max-height: 320px; overflow: auto; font-size: 12px; border-radius: 4px;">@selectedDetail.DecodedPayloadJson</pre>

            <FluentLabel Typo="Typography.Subject" Style="margin-top: 0.5rem;">Compact JWT</FluentLabel>
            <pre style="background: #1e1e1e; color: #d4d4d4; padding: 0.5rem; font-size: 11px; word-break: break-all; white-space: pre-wrap; border-radius: 4px;">@selectedDetail.SignedCredential</pre>

            <FluentStack Orientation="Orientation.Horizontal" Style="margin-top: 0.75rem; align-items: center; gap: 0.5rem;">
                <FluentButton Appearance="Appearance.Accent" OnClick="VerifyAsync"
                              IconStart="@(new Icons.Regular.Size16.Shield())">
                    Verify Signature
                </FluentButton>
                @if (verifyResult != null)
                {
                    <FluentMessageBar Intent="@(verifyResult.Valid ? MessageIntent.Success : MessageIntent.Error)"
                                      AllowDismiss="false" Style="flex: 1;">
                        @verifyResult.Message
                    </FluentMessageBar>
                }
            </FluentStack>
        }
    </FluentDialogBody>
    <FluentDialogFooter>
        <FluentButton Appearance="Appearance.Outline" OnClick="@(() => detailDialogHidden = true)">
            Close
        </FluentButton>
    </FluentDialogFooter>
</FluentDialog>
