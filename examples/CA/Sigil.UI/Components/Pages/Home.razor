@page "/"
@using Sigil.Common.Data

<PageTitle>Sigil - Dashboard</PageTitle>

<style>
    .dashboard-grid .col-title {
        padding-left: 0 !important;
    }
</style>

<FluentLabel Typo="Typography.PageTitle">Dashboard</FluentLabel>

@if (isLoading)
{
    <FluentProgressRing Style="margin: 2rem auto; display: block;" />
}
else
{
    @* --- Quick Stats Row --- *@
    <FluentStack Orientation="Orientation.Horizontal" Wrap="true" Style="margin-top: 1rem; gap: 1rem;">
        <FluentCard Style="min-width: 160px; flex: 1; text-align: center;">
            <div style="font-size: 2rem; font-weight: 700; color: #1976d2; margin-bottom: 0.35rem;">@communityCount</div>
            <FluentLabel Typo="Typography.Body" Style="opacity: 0.7;">Communities</FluentLabel>
        </FluentCard>
        <FluentCard Style="min-width: 160px; flex: 1; text-align: center;">
            <div style="font-size: 2rem; font-weight: 700; color: #2d6a4f; margin-bottom: 0.35rem;">@caCertCount</div>
            <FluentLabel Typo="Typography.Body" Style="opacity: 0.7;">CA Certificates</FluentLabel>
        </FluentCard>
        <FluentCard Style="min-width: 160px; flex: 1; text-align: center;">
            <div style="font-size: 2rem; font-weight: 700; color: #1976d2; margin-bottom: 0.35rem;">@issuedCertCount</div>
            <FluentLabel Typo="Typography.Body" Style="opacity: 0.7;">Issued Certificates</FluentLabel>
        </FluentCard>
        <FluentCard Style="min-width: 160px; flex: 1; text-align: center;">
            <div style="font-size: 2rem; font-weight: 700; color: #666; margin-bottom: 0.35rem;">@templateCount</div>
            <FluentLabel Typo="Typography.Body" Style="opacity: 0.7;">Templates</FluentLabel>
        </FluentCard>
        @if (revokedCertCount > 0)
        {
            <FluentCard Style="min-width: 160px; flex: 1; text-align: center;">
                <div style="font-size: 2rem; font-weight: 700; color: #9c27b0; margin-bottom: 0.35rem;">@revokedCertCount</div>
                <FluentLabel Typo="Typography.Body" Style="opacity: 0.7;">Revoked</FluentLabel>
            </FluentCard>
        }
    </FluentStack>

    @* --- Community Health --- *@
    @if (communitySummaries.Count > 0)
    {
        <FluentLabel Typo="Typography.Subject" Style="margin-top: 1.5rem;">Community Health</FluentLabel>
        <FluentStack Orientation="Orientation.Horizontal" Wrap="true" Style="margin-top: 0.5rem; gap: 1rem;">
            @foreach (var community in communitySummaries)
            {
                <FluentCard Style="min-width: 280px; flex: 1; cursor: pointer;"
                            @onclick="() => NavigateToCommunity(community.Id)">
                    <FluentStack Orientation="Orientation.Horizontal" Style="align-items: center; gap: 0.5rem; margin-bottom: 0.5rem;">
                        <FluentLabel Typo="Typography.Subject">@community.Name</FluentLabel>
                        <FluentSpacer />
                        @if (community.IsHealthy)
                        {
                            <FluentBadge BackgroundColor="#4caf50" Color="white" Style="font-size: 0.7rem;">Healthy</FluentBadge>
                        }
                        else if (community.TotalExpired > 0)
                        {
                            <FluentBadge BackgroundColor="#e94560" Color="white" Style="font-size: 0.7rem;">Action Needed</FluentBadge>
                        }
                        else
                        {
                            <FluentBadge BackgroundColor="#ff9800" Color="white" Style="font-size: 0.7rem;">Warning</FluentBadge>
                        }
                    </FluentStack>

                    <div style="display: grid; grid-template-columns: 1fr auto; gap: 0.25rem 1rem; font-size: 0.85rem;">
                        <span>CA Certificates</span>
                        <strong>@community.CaCount</strong>
                        <span>Issued Certificates</span>
                        <strong>@community.IssuedCount</strong>
                        @if (community.TotalExpiring > 0)
                        {
                            <span style="color: #ff9800;">Expiring Soon</span>
                            <strong style="color: #ff9800;">@community.TotalExpiring</strong>
                        }
                        @if (community.TotalExpired > 0)
                        {
                            <span style="color: #e94560;">Expired</span>
                            <strong style="color: #e94560;">@community.TotalExpired</strong>
                        }
                        @if (community.OverdueCrlCount > 0)
                        {
                            <span style="color: #e94560;">Overdue CRLs</span>
                            <strong style="color: #e94560;">@community.OverdueCrlCount</strong>
                        }
                    </div>
                </FluentCard>
            }
        </FluentStack>
    }
    else
    {
        <FluentCard Style="margin-top: 1rem;">
            <FluentLabel Typo="Typography.Subject">Getting Started</FluentLabel>
            <p style="margin-top: 0.5rem;">
                No communities found. <a href="/communities">Create a community</a> and then
                <a href="/explorer">import certificates</a> or generate a new Root CA to get started.
            </p>
        </FluentCard>
    }

    @* --- Expiring Certificates --- *@
    @if (expiringCerts.Count > 0)
    {
        <FluentCard Style="margin-top: 1.5rem;">
            <FluentLabel Typo="Typography.Subject" Style="margin-bottom: 0.5rem;">
                <FluentIcon Value="@(new Icons.Regular.Size16.Warning())" Color="Color.Custom" CustomColor="#ff9800" Style="margin-right: 0.35rem;" />
                Expiring Soon (@expiringCerts.Count)
            </FluentLabel>
            <FluentDataGrid Items="@expiringCerts.AsQueryable()" Class="dashboard-grid" Style="width: 100%;" GridTemplateColumns="1fr 0.6fr 0.8fr 0.5fr 0.5fr">
                <TemplateColumn Title="Name" Align="Align.Start">
                    <a href="/explorer/@context.CommunityId?thumbprint=@context.Thumbprint" style="color: #1976d2; cursor: pointer;"
                       @onclick="() => NavigateToCert(context.CommunityId, context.Thumbprint)" @onclick:preventDefault>
                        @context.Name
                    </a>
                </TemplateColumn>
                <PropertyColumn Property="@(c => c.CommunityName)" Title="Community" Align="Align.Start" />
                <TemplateColumn Title="Expires" Align="Align.Start">
                    <span style="color: @(context.DaysRemaining <= 7 ? "#e94560" : context.DaysRemaining <= 30 ? "#ff9800" : "inherit");">
                        @context.NotAfter.ToString("yyyy-MM-dd")
                    </span>
                </TemplateColumn>
                <TemplateColumn Title="Days Left" Align="Align.Start">
                    <FluentBadge BackgroundColor="@(context.DaysRemaining <= 7 ? "#e94560" : context.DaysRemaining <= 30 ? "#ff9800" : "#2d6a4f")"
                                 Color="white" Style="font-size: 0.75rem;">
                        @context.DaysRemaining d
                    </FluentBadge>
                </TemplateColumn>
                <PropertyColumn Property="@(c => c.CertType)" Title="Type" Align="Align.Start" />
            </FluentDataGrid>
        </FluentCard>
    }

    @* --- Expired Certificates --- *@
    @if (expiredCerts.Count > 0)
    {
        <FluentCard Style="margin-top: 1.5rem;">
            <FluentLabel Typo="Typography.Subject" Style="margin-bottom: 0.5rem;">
                <FluentIcon Value="@(new Icons.Regular.Size16.ErrorCircle())" Color="Color.Custom" CustomColor="#e94560" Style="margin-right: 0.35rem;" />
                Expired Certificates (@expiredCerts.Count)
            </FluentLabel>
            <FluentDataGrid Items="@expiredCerts.AsQueryable()" Class="dashboard-grid" Style="width: 100%;" GridTemplateColumns="1fr 0.6fr 0.8fr 0.5fr 0.5fr">
                <TemplateColumn Title="Name" Align="Align.Start">
                    <a href="/explorer/@context.CommunityId?thumbprint=@context.Thumbprint" style="color: #1976d2; cursor: pointer;"
                       @onclick="() => NavigateToCert(context.CommunityId, context.Thumbprint)" @onclick:preventDefault>
                        @context.Name
                    </a>
                </TemplateColumn>
                <PropertyColumn Property="@(c => c.CommunityName)" Title="Community" Align="Align.Start" />
                <TemplateColumn Title="Expired On" Align="Align.Start">
                    <span style="color: #e94560;">@context.NotAfter.ToString("yyyy-MM-dd")</span>
                </TemplateColumn>
                <TemplateColumn Title="Days Ago" Align="Align.Start">
                    <FluentBadge BackgroundColor="#e94560" Color="white" Style="font-size: 0.75rem;">
                        @(Math.Abs(context.DaysRemaining)) d ago
                    </FluentBadge>
                </TemplateColumn>
                <PropertyColumn Property="@(c => c.CertType)" Title="Type" Align="Align.Start" />
            </FluentDataGrid>
        </FluentCard>
    }

    @* --- Overdue CRLs --- *@
    @if (overdueCrls.Count > 0)
    {
        <FluentCard Style="margin-top: 1.5rem;">
            <FluentLabel Typo="Typography.Subject" Style="margin-bottom: 0.5rem;">
                <FluentIcon Value="@(new Icons.Regular.Size16.DocumentBulletList())" Color="Color.Custom" CustomColor="#e94560" Style="margin-right: 0.35rem;" />
                Overdue CRLs (@overdueCrls.Count)
            </FluentLabel>
            <FluentDataGrid Items="@overdueCrls.AsQueryable()" Class="dashboard-grid" Style="width: 100%;" GridTemplateColumns="0.4fr 1fr 0.8fr 0.8fr 0.5fr">
                <TemplateColumn Title="CRL #" Align="Align.Start">
                    <a href="/explorer/@context.CommunityId?thumbprint=@context.CaThumbprint" style="color: #1976d2; cursor: pointer;"
                       @onclick="() => NavigateToCert(context.CommunityId, context.CaThumbprint)" @onclick:preventDefault>
                        #@context.CrlNumber
                    </a>
                </TemplateColumn>
                <PropertyColumn Property="@(c => c.CaName)" Title="Issuing CA" Align="Align.Start" />
                <PropertyColumn Property="@(c => c.CommunityName)" Title="Community" Align="Align.Start" />
                <TemplateColumn Title="Next Update" Align="Align.Start">
                    <span style="color: #e94560;">@context.NextUpdate.ToString("yyyy-MM-dd")</span>
                </TemplateColumn>
                <TemplateColumn Title="Overdue" Align="Align.Start">
                    <FluentBadge BackgroundColor="#e94560" Color="white" Style="font-size: 0.75rem;">
                        @context.DaysOverdue d
                    </FluentBadge>
                </TemplateColumn>
            </FluentDataGrid>
        </FluentCard>
    }

    @* --- All Clear --- *@
    @if (communitySummaries.Count > 0 && expiringCerts.Count == 0 && expiredCerts.Count == 0 && overdueCrls.Count == 0)
    {
        <FluentCard Style="margin-top: 1.5rem; text-align: center; padding: 2rem;">
            <FluentIcon Value="@(new Icons.Regular.Size24.CheckmarkCircle())" Color="Color.Custom" CustomColor="#4caf50" />
            <FluentLabel Typo="Typography.Subject" Style="margin-top: 0.5rem;">All certificates are current</FluentLabel>
            <p style="opacity: 0.7; margin-top: 0.25rem;">No expiring certificates or overdue CRLs.</p>
        </FluentCard>
    }
}
