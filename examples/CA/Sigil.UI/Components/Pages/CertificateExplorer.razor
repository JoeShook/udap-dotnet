@page "/explorer"
@page "/explorer/{CommunityId:int}"
@using Sigil.Common.ViewModels
@using Sigil.Common.Services
@using Sigil.UI.Components.Shared
@using System.Security.Cryptography.X509Certificates

<PageTitle>Sigil - Certificate Explorer</PageTitle>

<FluentStack Orientation="Orientation.Horizontal" Style="align-items: center; gap: 0.75rem;">
    <FluentLabel Typo="Typography.PageTitle">Certificate Explorer</FluentLabel>
    @if (communityList.Count > 0)
    {
        <FluentSelect TOption="CommunityOption"
                      Items="@communityList"
                      OptionValue="@(o => o.Id.ToString())"
                      OptionText="@(o => o.Name)"
                      SelectedOptionChanged="OnCommunitySelected"
                      SelectedOption="@selectedCommunity"
                      Position="SelectPosition.Below"
                      Placeholder="Select a community..."
                      Style="min-width: 250px;" />
    }
    <FluentSpacer />
    @if (CommunityId > 0)
    {
        <FluentButton Appearance="Appearance.Accent"
                      IconStart="@(new Icons.Regular.Size16.ArrowImport())"
                      OnClick="@(() => showDropZone = !showDropZone)">
            Import Certificate
        </FluentButton>
        <FluentButton Appearance="Appearance.Outline"
                      IconStart="@(new Icons.Regular.Size16.ShieldKeyhole())"
                      OnClick="@(() => ShowIssuanceDialog(null, null))">
            New Root CA
        </FluentButton>
    }
</FluentStack>

@* Drop zone for importing certificates *@
@if (showDropZone && CommunityId > 0)
{
    <FluentCard Style="margin-top: 1rem;">
        <FluentLabel Typo="Typography.Subject">Import Certificates</FluentLabel>
        <p style="font-size: 0.85rem; opacity: 0.7; margin: 0.25rem 0 0.5rem;">
            Drop <code>.pfx</code>, <code>.cer</code>, <code>.pem</code>, or <code>.crl</code> files below.
            Multiple files accepted. Certificate role (CA / end-entity) is auto-detected.
            CRLs are matched to their issuing CA.
        </p>

        <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.75rem;">
            <FluentInputFile @ref="fileInput"
                             Mode="InputFileMode.SaveToTemporaryFolder"
                             MaximumFileSize="@(10 * 1024 * 1024)"
                             MaximumFileCount="100"
                             Accept=".pfx,.p12,.cer,.crt,.pem,.der,.crl"
                             OnCompleted="OnFilesCompleted"
                             DragDropZoneVisible="true"
                             Style="height: 120px; border: 2px dashed var(--accent-fill-rest); border-radius: 8px; cursor: pointer;">
                <ChildContent>
                    <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; opacity: 0.7; pointer-events: none;">
                        <FluentIcon Value="@(new Icons.Regular.Size24.ArrowUpload())" />
                        <span>Drag & drop files or click to select</span>
                    </div>
                </ChildContent>
            </FluentInputFile>

            <FluentStack Orientation="Orientation.Horizontal" Style="gap: 0.5rem; align-items: center;">
                <span style="opacity: 0.5; font-size: 0.85rem;">or</span>
                <FluentButton Appearance="Appearance.Outline"
                              IconStart="@(new Icons.Regular.Size16.Folder())"
                              OnClick="TriggerFolderUpload">
                    Upload Folder
                </FluentButton>
                <span style="opacity: 0.4; font-size: 0.8rem;">Includes all subfolders</span>
            </FluentStack>

            <InputFile @ref="folderInput"
                       OnChange="OnFolderSelected"
                       multiple
                       style="display: none;"
                       id="folder-input"
                       accept=".pfx,.p12,.cer,.crt,.pem,.der,.crl" />
        </FluentStack>

        @if (isImportingBatch)
        {
            <div style="margin-top: 0.5rem;">
                <FluentProgressBar Value="@importProgress" Max="@importTotal" />
                <span style="font-size: 0.8rem; opacity: 0.7;">
                    Processing @importProgress of @importTotal files...
                </span>
            </div>
        }

        @if (importErrors.Count > 0)
        {
            <FluentMessageBar Intent="MessageIntent.Warning" Style="margin-top: 0.5rem;">
                @importErrors.Count error(s) during import
            </FluentMessageBar>
            <ul style="font-size: 0.8rem; opacity: 0.7; margin-top: 0.25rem;">
                @foreach (var err in importErrors)
                {
                    <li>@err</li>
                }
            </ul>
        }

        @if (importError != null)
        {
            <FluentMessageBar Intent="MessageIntent.Error" Style="margin-top: 0.5rem;">
                @importError
            </FluentMessageBar>
        }
    </FluentCard>
}

@* Password dialog for PFX files *@
<FluentDialog @bind-Hidden="@passwordDialogHidden" Modal="true" TrapFocus="true"
              Style="min-width: 400px;">
    <FluentDialogHeader>PFX Password Required</FluentDialogHeader>
    <FluentDialogBody>
        <p style="font-size: 0.9rem;">Enter the password for <code>@pendingFileName</code></p>
        @if (pendingPasswordQueue.Count > 0)
        {
            <p style="font-size: 0.8rem; opacity: 0.5;">@pendingPasswordQueue.Count more file(s) waiting</p>
        }
        <FluentTextField @bind-Value="pfxPassword"
                         Label="Password"
                         TextFieldType="TextFieldType.Password"
                         Style="width: 100%;" />
        @if (passwordError != null)
        {
            <FluentMessageBar Intent="MessageIntent.Error" Style="margin-top: 0.5rem;">
                @passwordError
            </FluentMessageBar>
        }
    </FluentDialogBody>
    <FluentDialogFooter>
        <FluentButton Appearance="Appearance.Accent" OnClick="ImportWithPasswordAsync">Import</FluentButton>
        @if (pendingPasswordQueue.Count > 0)
        {
            <FluentButton Appearance="Appearance.Outline" OnClick="SkipPasswordFile">Skip</FluentButton>
        }
        <FluentButton Appearance="Appearance.Outline" OnClick="CancelPasswordDialog">Cancel</FluentButton>
    </FluentDialogFooter>
</FluentDialog>

@* Confirm import dialog showing parsed cert details *@
<FluentDialog @bind-Hidden="@confirmDialogHidden" Modal="true" TrapFocus="true"
              Style="min-width: 500px;">
    <FluentDialogHeader>Confirm Import</FluentDialogHeader>
    <FluentDialogBody>
        @if (parsedCert != null)
        {
            <div style="display: grid; grid-template-columns: 130px 1fr; gap: 0.4rem; font-size: 0.9rem;">
                <strong>File</strong>
                <span>@parsedCert.FileName</span>
                <strong>Detected Role</strong>
                <FluentBadge BackgroundColor="@GetRoleBadgeColor(parsedCert.DetectedRole)" Color="white">
                    @parsedCert.DetectedRole
                </FluentBadge>
                <strong>Subject</strong>
                <span>@parsedCert.Certificate.Subject</span>
                <strong>Issuer</strong>
                <span>@parsedCert.Certificate.Issuer</span>
                <strong>Algorithm</strong>
                <span>@parsedCert.Algorithm @(parsedCert.KeySize)-bit</span>
                <strong>Valid</strong>
                <span>@parsedCert.Certificate.NotBefore.ToString("yyyy-MM-dd") to @parsedCert.Certificate.NotAfter.ToString("yyyy-MM-dd")</span>
                <strong>Private Key</strong>
                <span>@(parsedCert.HasPrivateKey ? "Yes" : "No (public cert only)")</span>
                @if (chainMatchDescription != null)
                {
                    <strong>Chain Match</strong>
                    <span>@chainMatchDescription</span>
                }
            </div>

            <FluentTextField @bind-Value="importName"
                             Label="Certificate name"
                             Style="width: 100%; margin-top: 1rem;" />
        }
    </FluentDialogBody>
    <FluentDialogFooter>
        <FluentButton Appearance="Appearance.Accent" OnClick="ConfirmImportAsync"
                      Disabled="@(string.IsNullOrWhiteSpace(importName))">
            Import
        </FluentButton>
        <FluentButton Appearance="Appearance.Outline" OnClick="CancelConfirmDialog">Cancel</FluentButton>
    </FluentDialogFooter>
</FluentDialog>

@* Move to community dialog *@
<FluentDialog @bind-Hidden="@moveDialogHidden" Modal="true" TrapFocus="true"
              Style="min-width: 400px; overflow: visible;">
    <FluentDialogHeader>Move to Community</FluentDialogHeader>
    <FluentDialogBody Style="overflow: visible;">
        <p style="font-size: 0.9rem;">Move <code>@selectedNode?.Name</code> to:</p>
        <FluentSelect TOption="CommunityOption"
                      Items="@communityList.Where(c => c.Id != CommunityId).ToList()"
                      OptionValue="@(o => o.Id.ToString())"
                      OptionText="@(o => o.Name)"
                      @bind-SelectedOption="moveTargetCommunity"
                      Position="SelectPosition.Below"
                      Style="width: 100%; margin-top: 0.5rem;" />
    </FluentDialogBody>
    <FluentDialogFooter>
        <FluentButton Appearance="Appearance.Accent" OnClick="MoveSelectedAsync"
                      Disabled="@(moveTargetCommunity == null)">
            Move
        </FluentButton>
        <FluentButton Appearance="Appearance.Outline" OnClick="@(() => moveDialogHidden = true)">Cancel</FluentButton>
    </FluentDialogFooter>
</FluentDialog>

@* CA selection dialog for unmatched certs *@
<FluentDialog @bind-Hidden="@caSelectDialogHidden" Modal="true" TrapFocus="true"
              Style="min-width: 500px; overflow: visible;">
    <FluentDialogHeader>Select Issuing CA</FluentDialogHeader>
    <FluentDialogBody Style="overflow: visible;">
        <p style="font-size: 0.9rem;">
            No matching issuing CA was found for <code>@pendingFileName</code>.
        </p>
        <p style="font-size: 0.85rem; opacity: 0.7; margin: 0.25rem 0 0.75rem;">
            Select a CA to store this certificate under. The chain will show as untrusted, which is
            useful for testing invalid PKI scenarios.
        </p>
        @if (pendingCaSelectQueue.Count > 0)
        {
            <p style="font-size: 0.8rem; opacity: 0.5;">@pendingCaSelectQueue.Count more file(s) waiting</p>
        }
        <FluentSelect TOption="CaSelectOption"
                      Items="@availableCas"
                      OptionValue="@(o => o.Id.ToString())"
                      OptionText="@(o => o.DisplayName)"
                      @bind-SelectedOption="selectedCaForAssignment"
                      Position="SelectPosition.Below"
                      Style="width: 100%; margin-top: 0.5rem;" />
        @if (selectedCaForAssignment != null)
        {
            <div style="font-size: 0.8rem; opacity: 0.6; margin-top: 0.5rem;">
                <strong>Subject:</strong> @selectedCaForAssignment.Subject
            </div>
        }
    </FluentDialogBody>
    <FluentDialogFooter>
        <FluentButton Appearance="Appearance.Accent" OnClick="ConfirmCaAssignmentAsync"
                      Disabled="@(selectedCaForAssignment == null)">
            Assign
        </FluentButton>
        @if (pendingCaSelectQueue.Count > 0)
        {
            <FluentButton Appearance="Appearance.Outline" OnClick="SkipCaAssignment">Skip</FluentButton>
        }
        <FluentButton Appearance="Appearance.Outline" OnClick="CancelCaAssignment">Cancel</FluentButton>
    </FluentDialogFooter>
</FluentDialog>

@* Issue Certificate dialog *@
<FluentDialog @bind-Hidden="@issuanceDialogHidden" Modal="true" TrapFocus="true"
              Style="min-width: 600px; max-height: 80vh; overflow-y: auto;">
    <FluentDialogHeader>
        @if (issuingCaIdForIssuance == null)
        {
            <span>New Root CA (Self-Signed)</span>
        }
        else
        {
            <span>Issue Certificate — signed by @issuingCaNameForIssuance</span>
        }
    </FluentDialogHeader>
    <FluentDialogBody>
        <div style="display: flex; flex-direction: column; gap: 0.75rem;">
            @* Template selection *@
            <FluentSelect TOption="CertificateTemplate"
                          Items="@availableTemplates"
                          OptionText="@(t => $"{t.Name} ({GetCertTypeLabel(t.CertificateType)})")"
                          SelectedOptionChanged="OnTemplateSelected"
                          Label="Template"
                          Style="width: 100%;" />
            @if (selectedTemplate?.Description != null)
            {
                <p style="font-size: 0.8rem; opacity: 0.6; margin: -0.25rem 0 0;">@selectedTemplate.Description</p>
            }

            @* Subject DN *@
            <FluentTextField @bind-Value="issuanceSubjectDn" Label="Subject Distinguished Name"
                             Placeholder="CN=My Certificate, O=My Org, C=US"
                             Style="width: 100%;" />

            @* Certificate Name *@
            <FluentTextField @bind-Value="issuanceCertName" Label="Display Name (optional)"
                             Placeholder="Defaults to CN value"
                             Style="width: 100%;" />

            @* Validity *@
            <div style="display: flex; gap: 1rem;">
                <FluentDatePicker @bind-Value="issuanceNotBeforeNullable" Label="Not Before" Style="flex: 1;" />
                <FluentDatePicker @bind-Value="issuanceNotAfterNullable" Label="Not After" Style="flex: 1;" />
            </div>

            @* CDP / AIA URLs *@
            @if (selectedTemplate?.IncludeCdp == true)
            {
                <FluentTextField @bind-Value="issuanceCdpUrl" Label="CRL Distribution Point URL"
                                 Placeholder="http://crl.example.com/my.crl"
                                 Style="width: 100%;" />
            }
            @if (selectedTemplate?.IncludeAia == true)
            {
                <FluentTextField @bind-Value="issuanceAiaUrl" Label="Authority Information Access URL"
                                 Placeholder="http://crl.example.com/ca.cer"
                                 Style="width: 100%;" />
            }

            @* Subject Alternative Names *@
            <FluentLabel Typo="Typography.Subject" Style="margin-top: 0.25rem;">Subject Alternative Names</FluentLabel>
            @foreach (var san in issuanceSans)
            {
                <FluentStack Orientation="Orientation.Horizontal" Style="gap: 0.5rem; align-items: end;">
                    <FluentSelect TOption="SanType"
                                  Items="@sanTypeOptions"
                                  OptionText="@(s => s.ToString())"
                                  @bind-SelectedOption="san.Type"
                                  Style="width: 120px;" />
                    <FluentTextField @bind-Value="san.Value" Style="flex: 1;"
                                     Placeholder="@GetSanPlaceholder(san.Type)" />
                    <FluentButton Appearance="Appearance.Outline" Size="ButtonSize.Small"
                                  IconStart="@(new Icons.Regular.Size16.Delete())"
                                  OnClick="@(() => RemoveSanEntry(san))" />
                </FluentStack>
            }
            <FluentButton Appearance="Appearance.Outline" Size="ButtonSize.Small"
                          IconStart="@(new Icons.Regular.Size16.Add())"
                          OnClick="AddSanEntry">
                Add SAN
            </FluentButton>

            @* PFX Password *@
            <FluentTextField @bind-Value="issuancePfxPassword"
                             Label="PFX Password (for private key storage)"
                             TextFieldType="TextFieldType.Password"
                             Style="width: 100%;" />

            @* Template summary *@
            @if (selectedTemplate != null)
            {
                <div style="border: 1px solid var(--neutral-stroke-rest); border-radius: 4px; padding: 0.5rem; font-size: 0.8rem; opacity: 0.7;">
                    <strong>Template:</strong> @selectedTemplate.KeyAlgorithm
                    @if (selectedTemplate.KeyAlgorithm == "ECDSA")
                    {
                        @($" ({selectedTemplate.EcdsaCurve ?? "P-384"})")
                    }
                    else
                    {
                        @($" {selectedTemplate.KeySize}-bit")
                    }
                    | @selectedTemplate.HashAlgorithm
                    | @selectedTemplate.ValidityDays days
                    @if (selectedTemplate.IsBasicConstraintsCa)
                    {
                        @(" | CA")
                        @if (selectedTemplate.PathLengthConstraint.HasValue)
                        {
                            @($" (path: {selectedTemplate.PathLengthConstraint})")
                        }
                    }
                </div>
            }
        </div>
    </FluentDialogBody>
    <FluentDialogFooter>
        <FluentButton Appearance="Appearance.Accent" OnClick="IssueCertificateAsync"
                      Disabled="@(isIssuing || string.IsNullOrWhiteSpace(issuanceSubjectDn) || string.IsNullOrWhiteSpace(issuancePfxPassword) || selectedTemplate == null)">
            @(isIssuing ? "Generating..." : "Generate Certificate")
        </FluentButton>
        <FluentButton Appearance="Appearance.Outline" OnClick="@(() => issuanceDialogHidden = true)"
                      Disabled="@isIssuing">
            Cancel
        </FluentButton>
    </FluentDialogFooter>
</FluentDialog>

@* Re-sign Certificate dialog *@
<FluentDialog @bind-Hidden="@resignDialogHidden" Modal="true" TrapFocus="true"
              Style="min-width: 500px;">
    <FluentDialogHeader>Re-sign Certificate (Same Key)</FluentDialogHeader>
    <FluentDialogBody>
        <div style="display: flex; flex-direction: column; gap: 0.75rem;">
            <FluentMessageBar Intent="MessageIntent.Info">
                Re-signing creates a new certificate with the <strong>same key pair</strong> and extensions
                but a new serial number and validity period. Downstream certificates that chain to this
                certificate via AKI/SKI will continue to validate without re-issuance.
            </FluentMessageBar>

            @if (selectedNode != null)
            {
                <div style="display: grid; grid-template-columns: 120px 1fr; gap: 0.4rem; font-size: 0.9rem;">
                    <strong>Certificate</strong>
                    <span>@selectedNode.Name</span>
                    <strong>Subject</strong>
                    <span>@selectedCert?.Subject</span>
                </div>
            }

            <div style="display: flex; gap: 1rem;">
                <FluentDatePicker @bind-Value="resignNotBefore" Label="Not Before" Style="flex: 1;" />
                <FluentDatePicker @bind-Value="resignNotAfter" Label="Not After" Style="flex: 1;" />
            </div>

            <FluentTextField @bind-Value="resignPfxPassword"
                             Label="PFX Password (for private key storage)"
                             TextFieldType="TextFieldType.Password"
                             Style="width: 100%;" />
        </div>
    </FluentDialogBody>
    <FluentDialogFooter>
        <FluentButton Appearance="Appearance.Accent" OnClick="ResignCertificateAsync"
                      Disabled="@(isResigning || string.IsNullOrWhiteSpace(resignPfxPassword))">
            @(isResigning ? "Re-signing..." : "Re-sign Certificate")
        </FluentButton>
        <FluentButton Appearance="Appearance.Outline" OnClick="@(() => resignDialogHidden = true)"
                      Disabled="@isResigning">
            Cancel
        </FluentButton>
    </FluentDialogFooter>
</FluentDialog>

@if (treeNodes.Count > 0)
{
    <FluentSplitter Orientation="Orientation.Horizontal"
                    Panel1Size="33%"
                    Panel1MinSize="200px"
                    Panel2MinSize="300px"
                    BarSize="6"
                    BarHandle="true"
                    Style="margin-top: 1rem; height: calc(100vh - 200px);">
        <Panel1>
            <FluentCard Style="height: 100%; overflow-y: auto;">
                <FluentLabel Typo="Typography.Subject" Style="margin-bottom: 0.5rem;">
                    @selectedCommunityName
                </FluentLabel>
                <FluentTreeView @key="@treeVersion"
                                CurrentSelected="@selectedTreeItem"
                                CurrentSelectedChanged="OnTreeItemSelected">
                    @foreach (var root in treeNodes)
                    {
                        <FluentTreeItem Text="@root.Name"
                                        @key="@($"ca-{root.Id}")"
                                        Id="@($"tree-{root.Thumbprint}")"
                                        Data="@root"
                                        InitiallyExpanded="true"
                                        Style="@(IsError(root.Status) ? $"color: {NodeColor(root.Status)};" : "")">
                            <span slot="start" style="display: flex; align-items: center; gap: 0.35rem;">
                                <FluentIcon Value="@(new Icons.Regular.Size16.ShieldKeyhole())" Color="Color.Custom"
                                            CustomColor="@(IsError(root.Status) ? NodeColor(root.Status) : "#2d6a4f")" />
                                <CertBadge Status="@root.Status" />
                            </span>
                            @foreach (var intermediate in root.Children.Where(c => c.CertificateRole == "IntermediateCA"))
                            {
                                <FluentTreeItem Text="@intermediate.Name"
                                                @key="@($"ca-{intermediate.Id}")"
                                                Id="@($"tree-{intermediate.Thumbprint}")"
                                                Data="@intermediate"
                                                InitiallyExpanded="true"
                                                Style="@(IsError(intermediate.Status) ? $"color: {NodeColor(intermediate.Status)};" : "")">
                                    <span slot="start" style="display: flex; align-items: center; gap: 0.35rem;">
                                        <FluentIcon Value="@(new Icons.Regular.Size16.Shield())" Color="Color.Custom"
                                                    CustomColor="@(IsError(intermediate.Status) ? NodeColor(intermediate.Status) : "#1976d2")" />
                                        <CertBadge Status="@intermediate.Status" />
                                    </span>
                                    @foreach (var subCa in intermediate.Children.Where(c => c.CertificateRole == "IntermediateCA"))
                                    {
                                        @RenderCaTreeItem(subCa)
                                    }
                                    @foreach (var child in intermediate.Children.Where(c => c.CertificateRole == "EndEntity"))
                                    {
                                        <FluentTreeItem Text="@child.Name"
                                                        @key="@($"ee-{child.Id}")"
                                                        Id="@($"tree-{child.Thumbprint}")"
                                                        Data="@child"
                                                        Style="@(IsError(child.Status) ? $"color: {NodeColor(child.Status)};" : "")">
                                            <span slot="start" style="display: flex; align-items: center; gap: 0.35rem;">
                                                <FluentIcon Value="@(new Icons.Regular.Size16.Certificate())" Color="Color.Custom"
                                                            CustomColor="@(IsError(child.Status) ? NodeColor(child.Status) : "")"
                                                            Style="@(IsError(child.Status) ? "" : "opacity: 0.7;")" />
                                                <CertBadge Status="@child.Status" />
                                            </span>
                                        </FluentTreeItem>
                                    }
                                    @foreach (var crl in intermediate.Children.Where(c => c.CertificateRole == "CRL"))
                                    {
                                        <FluentTreeItem Text="@crl.Name"
                                                        @key="@($"crl-{crl.Id}")"
                                                        Data="@crl"
                                                        Style="@(IsError(crl.Status) ? $"color: {NodeColor(crl.Status)};" : "font-style: italic; opacity: 0.8;")">
                                            <span slot="start" style="display: flex; align-items: center; gap: 0.35rem;">
                                                <FluentIcon Value="@(new Icons.Regular.Size16.DocumentBulletList())" Color="Color.Custom"
                                                            CustomColor="@(IsError(crl.Status) ? NodeColor(crl.Status) : "")"
                                                            Style="@(IsError(crl.Status) ? "" : "opacity: 0.6;")" />
                                                <CrlBadge Status="@(crl.Status == CertificateStatus.Expired ? CrlTimeStatus.Expired : crl.Status == CertificateStatus.Expiring ? CrlTimeStatus.ExpiringSoon : CrlTimeStatus.Valid)" />
                                            </span>
                                        </FluentTreeItem>
                                    }
                                </FluentTreeItem>
                            }
                            @foreach (var issued in root.Children.Where(c => c.CertificateRole == "EndEntity"))
                            {
                                <FluentTreeItem Text="@issued.Name"
                                                @key="@($"ee-{issued.Id}")"
                                                Id="@($"tree-{issued.Thumbprint}")"
                                                Data="@issued"
                                                Style="@(IsError(issued.Status) ? $"color: {NodeColor(issued.Status)};" : "")">
                                    <span slot="start" style="display: flex; align-items: center; gap: 0.35rem;">
                                        <FluentIcon Value="@(new Icons.Regular.Size16.Certificate())" Color="Color.Custom"
                                                    CustomColor="@(IsError(issued.Status) ? NodeColor(issued.Status) : "")"
                                                    Style="@(IsError(issued.Status) ? "" : "opacity: 0.7;")" />
                                        <CertBadge Status="@issued.Status" />
                                    </span>
                                </FluentTreeItem>
                            }
                            @foreach (var crl in root.Children.Where(c => c.CertificateRole == "CRL"))
                            {
                                <FluentTreeItem Text="@crl.Name"
                                                @key="@($"crl-{crl.Id}")"
                                                Data="@crl"
                                                Style="@(IsError(crl.Status) ? $"color: {NodeColor(crl.Status)};" : "font-style: italic; opacity: 0.8;")">
                                    <span slot="start" style="display: flex; align-items: center; gap: 0.35rem;">
                                        <FluentIcon Value="@(new Icons.Regular.Size16.DocumentBulletList())" Color="Color.Custom"
                                                    CustomColor="@(IsError(crl.Status) ? NodeColor(crl.Status) : "")"
                                                    Style="@(IsError(crl.Status) ? "" : "opacity: 0.6;")" />
                                        <CrlBadge Status="@(crl.Status == CertificateStatus.Expired ? CrlTimeStatus.Expired : crl.Status == CertificateStatus.Expiring ? CrlTimeStatus.ExpiringSoon : CrlTimeStatus.Valid)" />
                                    </span>
                                </FluentTreeItem>
                            }
                        </FluentTreeItem>
                    }
                </FluentTreeView>
            </FluentCard>
        </Panel1>
        <Panel2>
            <div style="height: 100%; overflow-y: auto; overflow-x: hidden;">
            @if (selectedCrl != null)
            {
                @* CRL Detail Panel *@
                <FluentCard Style="height: auto;">
                    <FluentStack Orientation="Orientation.Horizontal" Style="align-items: center; gap: 0.5rem;">
                        <FluentLabel Typo="Typography.Subject">CRL #@selectedCrl.CrlNumber</FluentLabel>
                        <FluentSpacer />
                        <CrlBadge Status="@selectedCrl.TimeStatus" />
                        @if (selectedCrl.SignatureValid)
                        {
                            <FluentBadge BackgroundColor="#4caf50" Color="white" Style="font-size: 0.75rem;">Sig Valid</FluentBadge>
                        }
                        else
                        {
                            <FluentBadge BackgroundColor="#e94560" Color="white" Style="font-size: 0.75rem;">Sig INVALID</FluentBadge>
                        }
                    </FluentStack>

                    <FluentStack Orientation="Orientation.Horizontal" Style="margin-top: 0.5rem; gap: 0.5rem;" Wrap="true">
                        <FluentAnchor Href="@($"/api/crl/{selectedCrl.Id}/download")"
                                      Appearance="Appearance.Outline"
                                      title="Download .crl">
                            <FluentIcon Value="@(new Icons.Regular.Size16.ArrowDownload())" />
                            .crl
                        </FluentAnchor>
                        <FluentButton Appearance="Appearance.Outline"
                                      IconStart="@(new Icons.Regular.Size16.Delete())"
                                      OnClick="DeleteSelectedAsync"
                                      title="Delete this CRL"
                                      Style="color: #e94560;">
                            Delete
                        </FluentButton>
                    </FluentStack>

                    <FluentAccordion Style="margin-top: 1rem;">
                        <FluentAccordionItem Heading="General Information" Expanded="true">
                            <div style="display: grid; grid-template-columns: 150px 1fr; gap: 0.5rem; font-size: 0.9rem;">
                                <strong>CRL Number</strong>
                                <span>@selectedCrl.CrlNumber</span>
                                <strong>Issuing CA</strong>
                                <span>@selectedCrl.CaName</span>
                                <strong>This Update</strong>
                                <span>@selectedCrl.ThisUpdate.ToString("yyyy-MM-dd HH:mm:ss UTC")</span>
                                <strong>Next Update</strong>
                                <span>@selectedCrl.NextUpdate.ToString("yyyy-MM-dd HH:mm:ss UTC")</span>
                                <strong>Algorithm</strong>
                                <span>@selectedCrl.SignatureAlgorithm</span>
                                <strong>Signature</strong>
                                <span>@(selectedCrl.SignatureValid ? "Valid — verified against issuing CA" : "INVALID — does not match issuing CA")</span>
                                <strong>Revoked Certs</strong>
                                <span>@selectedCrl.RevokedCount</span>
                                <strong>File</strong>
                                <span>@(selectedCrl.FileName ?? "(none)")</span>
                                <strong>Imported</strong>
                                <span>@selectedCrl.ImportedAt.ToString("yyyy-MM-dd HH:mm:ss UTC")</span>
                            </div>
                        </FluentAccordionItem>

                        @if (selectedCrl.RevokedCertificates.Count > 0)
                        {
                            <FluentAccordionItem Heading="@($"Revoked Certificates ({selectedCrl.RevokedCertificates.Count})")" Expanded="true">
                                <FluentDataGrid Items="@selectedCrl.RevokedCertificates.AsQueryable()" Style="font-size: 0.85rem;">
                                    <PropertyColumn Property="@(r => r.SerialNumber)" Title="Serial Number" />
                                    <PropertyColumn Property="@(r => r.RevocationDate.ToString("yyyy-MM-dd HH:mm"))" Title="Revocation Date" />
                                    <PropertyColumn Property="@(r => r.ReasonName)" Title="Reason" />
                                </FluentDataGrid>
                            </FluentAccordionItem>
                        }

                        <FluentAccordionItem Heading="ASN.1 Structure">
                            <Asn1TreeView RootNode="@asn1Root" />
                        </FluentAccordionItem>
                    </FluentAccordion>
                </FluentCard>
            }
            else if (selectedCert != null)
            {
                @* Certificate Detail Panel *@
                <FluentCard Style="height: auto;">
                    <FluentStack Orientation="Orientation.Horizontal"
                                 Style="align-items: center; gap: 0.5rem; background-color: rgba(45, 106, 79, 0.4); border-left: 3px solid #2d6a4f; border-radius: 0 4px 4px 0; margin: -0.5rem -0.5rem 0 -0.5rem; padding: 0.5rem;">
                        <FluentLabel Typo="Typography.Subject">@selectedNode?.Name</FluentLabel>
                        <FluentSpacer />
                        @if (selectedNodeHasPrivateKey)
                        {
                            <FluentBadge BackgroundColor="#2d6a4f" Color="white" Style="font-size: 0.75rem;">Operational</FluentBadge>
                        }
                        else
                        {
                            <FluentBadge BackgroundColor="#666" Color="white" Style="font-size: 0.75rem;">Trust Only</FluentBadge>
                        }
                        <CertBadge Status="@(selectedNode?.Status ?? CertificateStatus.Valid)" />
                    </FluentStack>

                    <FluentStack Orientation="Orientation.Horizontal" Style="margin-top: 0.5rem; gap: 0.5rem;" Wrap="true">
                        <FluentAnchor Href="@GetCerDownloadUrl()"
                                      Appearance="Appearance.Outline"
                                      title="Download public certificate (.cer PEM)">
                            <FluentIcon Value="@(new Icons.Regular.Size16.ArrowDownload())" />
                            .cer
                        </FluentAnchor>
                        @if (selectedNodeHasPrivateKey)
                        {
                            <FluentAnchor Href="@GetPfxDownloadUrl()"
                                          Appearance="Appearance.Outline"
                                          title="Download certificate + private key (.p12)">
                                <FluentIcon Value="@(new Icons.Regular.Size16.ArrowDownload())" />
                                .p12
                            </FluentAnchor>
                        }
                        <FluentButton Appearance="Appearance.Outline"
                                      IconStart="@(new Icons.Regular.Size16.ArrowForward())"
                                      OnClick="ShowMoveDialog"
                                      title="Move to another community">
                            Move
                        </FluentButton>
                        <FluentButton Appearance="Appearance.Outline"
                                      IconStart="@(new Icons.Regular.Size16.Delete())"
                                      OnClick="DeleteSelectedAsync"
                                      title="Delete this certificate"
                                      Style="color: #e94560;">
                            Delete
                        </FluentButton>
                        @if (selectedNodeHasPrivateKey && selectedNode?.CertificateRole is "RootCA" or "IntermediateCA")
                        {
                            <FluentButton Appearance="Appearance.Accent"
                                          IconStart="@(new Icons.Regular.Size16.Add())"
                                          OnClick="@(() => ShowIssuanceDialog(selectedNode.Id, selectedNode.Name))"
                                          title="Issue a new certificate signed by this CA">
                                Issue Certificate
                            </FluentButton>
                        }
                        <FluentButton Appearance="Appearance.Outline"
                                      IconStart="@(new Icons.Regular.Size16.ArrowRepeatAll())"
                                      OnClick="ShowRenewDialog"
                                      title="Re-key: new key pair, new serial, new validity. Downstream certs need re-issuance.">
                            Re-key
                        </FluentButton>
                        @if (selectedNodeHasPrivateKey && selectedNode?.CertificateRole is "RootCA" or "IntermediateCA")
                        {
                            <FluentButton Appearance="Appearance.Outline"
                                          IconStart="@(new Icons.Regular.Size16.ArrowRepeatAll())"
                                          OnClick="ShowResignDialog"
                                          title="Re-sign: same key, new serial and validity. Downstream certs remain valid.">
                                Re-sign
                            </FluentButton>
                        }
                    </FluentStack>

                    <FluentAccordion Style="margin-top: 1rem;">
                        <FluentAccordionItem Heading="General Information" Expanded="true">
                            <div style="display: grid; grid-template-columns: 150px 1fr; gap: 0.5rem; font-size: 0.9rem;">
                                <strong>Subject</strong>
                                <span>@selectedCert.Subject</span>
                                <strong>Issuer</strong>
                                <span style="display: flex; align-items: center; gap: 0.35rem;">
                                    @selectedCert.Issuer
                                    @if (selectedCert.Subject != selectedCert.Issuer)
                                    {
                                        <FluentButton Appearance="Appearance.Stealth" Size="ButtonSize.Small"
                                                      IconStart="@(new Icons.Regular.Size16.Link())"
                                                      OnClick="LoadIssuerDetailsAsync"
                                                      title="View issuer certificate details"
                                                      Style="min-width: 24px; padding: 2px;" />
                                    }
                                </span>
                                <strong>Serial Number</strong>
                                <code>@selectedCert.SerialNumber</code>
                                <strong>Thumbprint</strong>
                                <code>@selectedCert.Thumbprint</code>
                                <strong>Not Before</strong>
                                <span>@selectedCert.NotBefore.ToString("yyyy-MM-dd HH:mm:ss UTC")</span>
                                <strong>Not After</strong>
                                <span>@selectedCert.NotAfter.ToString("yyyy-MM-dd HH:mm:ss UTC")</span>
                                <strong>Algorithm</strong>
                                <span>@selectedCert.SignatureAlgorithm.FriendlyName</span>
                                <strong>Public Key</strong>
                                <span>@GetPublicKeyInfo()</span>
                                <strong>Private Key</strong>
                                <span>@(selectedNodeHasPrivateKey ? "Yes (stored)" : "No (public cert only)")</span>
                            </div>
                        </FluentAccordionItem>

                        @if (subjectAltNames.Count > 0)
                        {
                            <FluentAccordionItem Heading="Subject Alternative Names">
                                <ul style="margin: 0; padding-left: 1.5rem; font-size: 0.9rem;">
                                    @foreach (var san in subjectAltNames)
                                    {
                                        <li><code>@san</code></li>
                                    }
                                </ul>
                            </FluentAccordionItem>
                        }

                        @if (chainValidation != null)
                        {
                            <FluentAccordionItem Heading="@($"Chain Validation {(chainValidation.IsValid ? "(Trusted)" : "(UNTRUSTED)")}")" Expanded="true">
                                <FluentStack Orientation="Orientation.Horizontal" Style="margin-bottom: 0.75rem; gap: 0.5rem; align-items: center;">
                                    <FluentButton Appearance="Appearance.Outline" OnClick="RevalidateSelectedAsync"
                                                  Title="Re-run chain validation and CRL checks"
                                                  Disabled="isRevalidating">
                                        <FluentIcon Value="new Icons.Regular.Size16.ArrowSync()" />
                                        @(isRevalidating ? "Validating..." : "Revalidate")
                                    </FluentButton>
                                    @if (chainValidation.IsValid)
                                    {
                                        <FluentBadge BackgroundColor="#4caf50" Color="white">Chain Valid</FluentBadge>
                                    }
                                    else
                                    {
                                        <FluentBadge BackgroundColor="#d32f2f" Color="white">Chain Invalid</FluentBadge>
                                    }
                                    @if (chainValidation.ReachedTrustAnchor)
                                    {
                                        <FluentBadge BackgroundColor="#2d6a4f" Color="white">Trust Anchor Found</FluentBadge>
                                    }
                                    else
                                    {
                                        <FluentBadge BackgroundColor="#e94560" Color="white">No Trust Anchor</FluentBadge>
                                    }
                                </FluentStack>

                                @if (chainValidation.Error != null)
                                {
                                    <FluentMessageBar Intent="MessageIntent.Error">@chainValidation.Error</FluentMessageBar>
                                }

                                @foreach (var link in chainValidation.ChainLinks)
                                {
                                    <div style="border-left: 3px solid @(link.HasProblems ? "#e94560" : "#4caf50"); padding: 0.5rem 0.75rem; margin-bottom: 0.5rem; font-size: 0.85rem;">
                                        <FluentStack Orientation="Orientation.Horizontal" Style="gap: 0.5rem; align-items: center;">
                                            <strong>@link.Name</strong>
                                            @if (link.IsTrustAnchor)
                                            {
                                                <FluentBadge BackgroundColor="#2d6a4f" Color="white" Style="font-size: 0.7rem;">Root</FluentBadge>
                                            }
                                            @if (link.SignatureValid == true)
                                            {
                                                <FluentBadge BackgroundColor="#4caf50" Color="white" Style="font-size: 0.7rem;">Sig OK</FluentBadge>
                                            }
                                            else if (link.SignatureValid == false)
                                            {
                                                <FluentBadge BackgroundColor="#e94560" Color="white" Style="font-size: 0.7rem;">Sig Fail</FluentBadge>
                                            }
                                            @switch (link.CrlStatus)
                                            {
                                                case CrlCheckStatus.Good:
                                                    <FluentBadge BackgroundColor="#4caf50" Color="white" Style="font-size: 0.7rem;"
                                                                 title="@(link.CrlSource == CrlSource.Downloaded ? $"Downloaded from {link.CrlSourceUrl}" : "From stored CRL")">
                                                        CRL OK
                                                    </FluentBadge>
                                                    @if (link.CrlSource == CrlSource.Downloaded)
                                                    {
                                                        <span style="font-size: 0.7rem; font-weight: 600;">↓</span>
                                                        <span style="font-size: 0.7rem; color: #1976d2; font-weight: 600;">Downloaded</span>
                                                    }
                                                    break;
                                                case CrlCheckStatus.Revoked:
                                                    <FluentBadge BackgroundColor="#9c27b0" Color="white" Style="font-size: 0.7rem;">REVOKED</FluentBadge>
                                                    break;
                                                case CrlCheckStatus.NoCrlAvailable:
                                                    <FluentBadge BackgroundColor="#ff9800" Color="white" Style="font-size: 0.7rem;">No CRL</FluentBadge>
                                                    break;
                                                case CrlCheckStatus.CrlExpired:
                                                    <FluentBadge BackgroundColor="#ff9800" Color="white" Style="font-size: 0.7rem;">CRL Expired</FluentBadge>
                                                    break;
                                                case CrlCheckStatus.CrlFetchFailed:
                                                    <FluentBadge BackgroundColor="#e94560" Color="white" Style="font-size: 0.7rem;">CRL Fetch Failed</FluentBadge>
                                                    break;
                                            }
                                        </FluentStack>
                                        <div style="opacity: 0.7; font-size: 0.8rem;">@link.Subject</div>
                                        @if (link.CrlSource == CrlSource.Downloaded && link.CrlSourceUrl != null)
                                        {
                                            <div style="font-size: 0.75rem; color: #1976d2; margin-top: 0.15rem;">
                                                CRL resolved from: @link.CrlSourceUrl
                                            </div>
                                        }
                                        @if (link.HasProblems)
                                        {
                                            <ul style="color: #e94560; margin: 0.25rem 0 0; padding-left: 1.25rem; font-size: 0.8rem;">
                                                @foreach (var problem in link.Problems)
                                                {
                                                    <li>@problem</li>
                                                }
                                            </ul>
                                        }
                                    </div>
                                }
                            </FluentAccordionItem>
                        }

                        <FluentAccordionItem Heading="Extensions">
                            <ExtensionTable Certificate="@selectedCert" />
                        </FluentAccordionItem>

                        <FluentAccordionItem Heading="ASN.1 Structure">
                            <Asn1TreeView RootNode="@asn1Root" />
                        </FluentAccordionItem>
                    </FluentAccordion>
                </FluentCard>

                @* Issuer Detail Panel *@
                @if (issuerCert != null)
                {
                    <div style="border-top: 3px solid #1976d2; margin-top: 0.5rem;"></div>
                    <FluentCard Style="height: auto; border-left: 3px solid #1976d2;">
                        <FluentStack Orientation="Orientation.Horizontal"
                                     Style="align-items: center; gap: 0.5rem; background-color: rgba(25, 118, 210, 0.3); border-left: 3px solid #1976d2; border-radius: 0 4px 4px 0; margin: -0.5rem -0.5rem 0 -0.5rem; padding: 0.5rem;">
                            <FluentIcon Value="@(new Icons.Regular.Size16.Link())" Color="Color.Custom" CustomColor="#1976d2" />
                            <FluentLabel Typo="Typography.Subject">@issuerNode?.Name</FluentLabel>
                            <FluentBadge BackgroundColor="#1976d2" Color="white" Style="font-size: 0.7rem;">Issuer</FluentBadge>
                            <FluentSpacer />
                            <FluentButton Appearance="Appearance.Stealth" Size="ButtonSize.Small"
                                          IconStart="@(new Icons.Regular.Size16.Dismiss())"
                                          OnClick="CloseIssuerDetailsAsync"
                                          title="Close issuer details" />
                        </FluentStack>

                        <FluentAccordion Style="margin-top: 0.75rem;">
                            <FluentAccordionItem Heading="General Information" Expanded="true">
                                <div style="display: grid; grid-template-columns: 150px 1fr; gap: 0.5rem; font-size: 0.9rem;">
                                    <strong>Subject</strong>
                                    <span>@issuerCert.Subject</span>
                                    <strong>Issuer</strong>
                                    <span style="display: flex; align-items: center; gap: 0.35rem;">
                                        @issuerCert.Issuer
                                        @if (issuerCert.Subject != issuerCert.Issuer)
                                        {
                                            <FluentButton Appearance="Appearance.Stealth" Size="ButtonSize.Small"
                                                          IconStart="@(new Icons.Regular.Size16.Link())"
                                                          OnClick="LoadIssuerOfIssuerDetailsAsync"
                                                          title="View this issuer's issuer"
                                                          Style="min-width: 24px; padding: 2px;" />
                                        }
                                    </span>
                                    <strong>Serial Number</strong>
                                    <code>@issuerCert.SerialNumber</code>
                                    <strong>Thumbprint</strong>
                                    <code>@issuerCert.Thumbprint</code>
                                    <strong>Not Before</strong>
                                    <span>@issuerCert.NotBefore.ToString("yyyy-MM-dd HH:mm:ss UTC")</span>
                                    <strong>Not After</strong>
                                    <span>@issuerCert.NotAfter.ToString("yyyy-MM-dd HH:mm:ss UTC")</span>
                                    <strong>Algorithm</strong>
                                    <span>@issuerCert.SignatureAlgorithm.FriendlyName</span>
                                    <strong>Public Key</strong>
                                    <span>@GetIssuerPublicKeyInfo()</span>
                                </div>
                            </FluentAccordionItem>

                            <FluentAccordionItem Heading="Extensions">
                                <ExtensionTable Certificate="@issuerCert" />
                            </FluentAccordionItem>

                            <FluentAccordionItem Heading="ASN.1 Structure">
                                <Asn1TreeView RootNode="@issuerAsn1Root" />
                            </FluentAccordionItem>
                        </FluentAccordion>
                    </FluentCard>
                }
            }
            else
            {
                <FluentCard Style="height: 100%; display: flex; align-items: center; justify-content: center;">
                    <span style="opacity: 0.5;">Select a certificate or CRL from the tree to view details</span>
                </FluentCard>
            }
            </div>
        </Panel2>
    </FluentSplitter>
}
else if (CommunityId > 0 && !showDropZone)
{
    <FluentCard Style="margin-top: 1rem;">
        <p>No certificates found in this community.
            <FluentAnchor Href="javascript:void(0)" OnClick="@(() => showDropZone = true)">Import a certificate</FluentAnchor> to get started.
        </p>
    </FluentCard>
}

@code {
    private RenderFragment RenderCaTreeItem(CertificateChainNodeViewModel caNode) => __builder =>
    {
        <FluentTreeItem Text="@caNode.Name"
                        @key="@($"ca-{caNode.Id}")"
                        Id="@($"tree-{caNode.Thumbprint}")"
                        Data="@caNode"
                        InitiallyExpanded="true"
                        Style="@(IsError(caNode.Status) ? $"color: {NodeColor(caNode.Status)};" : "")">
            <span slot="start" style="display: flex; align-items: center; gap: 0.35rem;">
                @if (caNode.CertificateRole == "RootCA")
                {
                    <FluentIcon Value="@(new Icons.Regular.Size16.ShieldKeyhole())" Color="Color.Custom"
                                CustomColor="@(IsError(caNode.Status) ? NodeColor(caNode.Status) : "#2d6a4f")" />
                }
                else
                {
                    <FluentIcon Value="@(new Icons.Regular.Size16.Shield())" Color="Color.Custom"
                                CustomColor="@(IsError(caNode.Status) ? NodeColor(caNode.Status) : "#1976d2")" />
                }
                <CertBadge Status="@caNode.Status" />
            </span>
            @* Recursive: sub-CA nodes *@
            @foreach (var subCa in caNode.Children.Where(c => c.CertificateRole is "IntermediateCA" or "RootCA"))
            {
                @RenderCaTreeItem(subCa)
            }
            @* End-entity certs *@
            @foreach (var issued in caNode.Children.Where(c => c.CertificateRole == "EndEntity"))
            {
                <FluentTreeItem Text="@issued.Name"
                                @key="@($"ee-{issued.Id}")"
                                Id="@($"tree-{issued.Thumbprint}")"
                                Data="@issued"
                                Style="@(IsError(issued.Status) ? $"color: {NodeColor(issued.Status)};" : "")">
                    <span slot="start" style="display: flex; align-items: center; gap: 0.35rem;">
                        <FluentIcon Value="@(new Icons.Regular.Size16.Certificate())" Color="Color.Custom"
                                    CustomColor="@(IsError(issued.Status) ? NodeColor(issued.Status) : "")"
                                    Style="@(IsError(issued.Status) ? "" : "opacity: 0.7;")" />
                        <CertBadge Status="@issued.Status" />
                    </span>
                </FluentTreeItem>
            }
            @* CRL nodes *@
            @foreach (var crl in caNode.Children.Where(c => c.CertificateRole == "CRL"))
            {
                <FluentTreeItem Text="@crl.Name"
                                @key="@($"crl-{crl.Id}")"
                                Data="@crl"
                                Style="@(IsError(crl.Status) ? $"color: {NodeColor(crl.Status)};" : "font-style: italic; opacity: 0.8;")">
                    <span slot="start" style="display: flex; align-items: center; gap: 0.35rem;">
                        <FluentIcon Value="@(new Icons.Regular.Size16.DocumentBulletList())" Color="Color.Custom"
                                    CustomColor="@(IsError(crl.Status) ? NodeColor(crl.Status) : "")"
                                    Style="@(IsError(crl.Status) ? "" : "opacity: 0.6;")" />
                        <CrlBadge Status="@(crl.Status == CertificateStatus.Expired ? CrlTimeStatus.Expired : crl.Status == CertificateStatus.Expiring ? CrlTimeStatus.ExpiringSoon : CrlTimeStatus.Valid)" />
                    </span>
                </FluentTreeItem>
            }
        </FluentTreeItem>
    };
}
