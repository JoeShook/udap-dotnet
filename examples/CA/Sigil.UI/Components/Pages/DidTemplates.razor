@page "/did-templates"
@using Sigil.Common.Data.Entities

<PageTitle>Sigil - DID Templates</PageTitle>

<FluentLabel Typo="Typography.PageTitle">DID Templates</FluentLabel>

<FluentCard Style="margin-top: 1rem;">
    <FluentStack Orientation="Orientation.Horizontal" Style="align-items: center; gap: 0.5rem;">
        <FluentLabel Typo="Typography.Subject">Templates for minting DIDs (Phase A: did:key)</FluentLabel>
        <FluentSpacer />
        <FluentButton Appearance="Appearance.Accent" OnClick="ShowAddDialog"
                      IconStart="@(new Icons.Regular.Size16.Add())">
            New DID Template
        </FluentButton>
    </FluentStack>

    <FluentDataGrid Items="@templates.AsQueryable()" Style="margin-top: 0.5rem;" ResizableColumns="true"
                    GridTemplateColumns="minmax(180px, 1.5fr) minmax(200px, 2fr) 90px 110px minmax(180px, 1.5fr) 90px auto">
        <PropertyColumn Property="@(t => t.Name)" Title="Name" Sortable="true" IsDefaultSortColumn="true" />
        <PropertyColumn Property="@(t => t.Description)" Title="Description" />
        <PropertyColumn Property="@(t => t.Method)" Title="Method" Sortable="true" />
        <PropertyColumn Property="@(t => t.KeyAlgorithm)" Title="Key Algorithm" />
        <PropertyColumn Property="@(t => t.DefaultPurposes)" Title="Default Purposes" />
        <TemplateColumn Title="Preset">
            @if (context.IsPreset)
            {
                <FluentBadge Appearance="Appearance.Accent">preset</FluentBadge>
            }
        </TemplateColumn>
        <TemplateColumn Title="Actions">
            <FluentStack Orientation="Orientation.Horizontal" Wrap="true" Style="gap: 0.25rem;">
                <FluentButton Size="ButtonSize.Small" Appearance="Appearance.Outline"
                              IconStart="@(new Icons.Regular.Size16.Edit())"
                              OnClick="@(() => ShowEditDialog(context))">
                    Edit
                </FluentButton>
                @if (!context.IsPreset)
                {
                    <FluentButton Size="ButtonSize.Small" Appearance="Appearance.Outline"
                                  IconStart="@(new Icons.Regular.Size16.Delete())"
                                  OnClick="@(() => DeleteAsync(context))">
                        Delete
                    </FluentButton>
                }
            </FluentStack>
        </TemplateColumn>
    </FluentDataGrid>
</FluentCard>

<FluentDialog @bind-Hidden="@dialogHidden" Modal="true" TrapFocus="true"
              Style="min-width: 600px; max-height: 80vh; overflow: auto;">
    <FluentDialogHeader>@(isEditing ? "Edit DID Template" : "New DID Template")</FluentDialogHeader>
    <FluentDialogBody>
        <FluentTextField @bind-Value="editName" Label="Name" Style="width: 100%;"
                         Placeholder="did:key (Ed25519)" />
        <FluentTextField @bind-Value="editDescription" Label="Description" Style="width: 100%; margin-top: 0.5rem;"
                         Placeholder="Self-describing DID using Ed25519." />

        <FluentSelect TOption="string" @bind-Value="editMethod" Label="Method"
                      Style="margin-top: 0.5rem; width: 200px;">
            @foreach (var m in supportedMethods)
            {
                <FluentOption Value="@m">@m</FluentOption>
            }
        </FluentSelect>

        <FluentSelect TOption="string" @bind-Value="editKeyAlgorithm" Label="Key Algorithm"
                      Style="margin-top: 0.5rem; width: 200px;">
            @foreach (var a in supportedAlgorithms)
            {
                <FluentOption Value="@a">@a</FluentOption>
            }
        </FluentSelect>

        <FluentTextField @bind-Value="editDefaultPurposes" Label="Default Purposes (semicolon-delimited)"
                         Style="width: 100%; margin-top: 0.5rem;"
                         Placeholder="assertionMethod;authentication" />
    </FluentDialogBody>
    <FluentDialogFooter>
        <FluentButton Appearance="Appearance.Accent" OnClick="SaveAsync"
                      Disabled="@(string.IsNullOrWhiteSpace(editName))">
            @(isEditing ? "Save" : "Create")
        </FluentButton>
        <FluentButton Appearance="Appearance.Outline" OnClick="@(() => dialogHidden = true)">
            Cancel
        </FluentButton>
    </FluentDialogFooter>
</FluentDialog>
