@page "/import"

<PageTitle>Sigil - Import Certificates</PageTitle>

<FluentLabel Typo="Typography.PageTitle">Import Certificates</FluentLabel>

<FluentCard Style="margin-top: 1rem;">
    <FluentLabel Typo="Typography.Subject">Source Directory</FluentLabel>
    <FluentStack Orientation="Orientation.Horizontal" Style="margin-top: 0.5rem; gap: 0.5rem; align-items: flex-end;">
        <FluentTextField @bind-Value="certstorePath"
                         Style="flex: 1;"
                         Label="Certstores path"
                         Placeholder="Path to certstores directory" />
        <FluentTextField @bind-Value="pfxPassword"
                         Style="width: 200px;"
                         Label="PFX password"
                         TextFieldType="TextFieldType.Password" />
        <FluentButton Appearance="Appearance.Accent"
                      OnClick="ScanAsync"
                      Loading="@isScanning"
                      Disabled="@(string.IsNullOrWhiteSpace(certstorePath))">
            Scan
        </FluentButton>
    </FluentStack>
</FluentCard>

@if (previews.Count > 0)
{
    <FluentCard Style="margin-top: 1rem;">
        <FluentStack Orientation="Orientation.Horizontal" Style="align-items: center; gap: 0.5rem;">
            <FluentLabel Typo="Typography.Subject">Preview</FluentLabel>
            <FluentSpacer />
            <FluentButton Appearance="Appearance.Accent"
                          OnClick="ImportAllAsync"
                          Loading="@isImporting"
                          Disabled="@(!previews.Any(p => p.IsValid))">
                Import All
            </FluentButton>
        </FluentStack>

        <FluentDataGrid Items="@previews.AsQueryable()" Style="margin-top: 0.5rem;">
            <PropertyColumn Property="@(p => p.CommunityName)" Title="Community" Sortable="true" />
            <PropertyColumn Property="@(p => p.RootCaCount)" Title="Root CAs" />
            <PropertyColumn Property="@(p => p.IntermediateCount)" Title="Intermediates" />
            <PropertyColumn Property="@(p => p.IssuedCertCount)" Title="Issued" />
            <PropertyColumn Property="@(p => p.CrlCount)" Title="CRLs" />
            <TemplateColumn Title="Status">
                @if (context.IsValid)
                {
                    <FluentBadge BackgroundColor="#4caf50" Color="white">Ready</FluentBadge>
                }
                else
                {
                    <FluentBadge BackgroundColor="#e94560" Color="white">
                        @($"{context.Errors.Count} error(s)")
                    </FluentBadge>
                }
            </TemplateColumn>
            <TemplateColumn Title="Action">
                <FluentButton Size="ButtonSize.Small"
                              Appearance="Appearance.Outline"
                              OnClick="@(() => ImportSingleAsync(context))"
                              Disabled="@(!context.IsValid || isImporting)">
                    Import
                </FluentButton>
            </TemplateColumn>
        </FluentDataGrid>
    </FluentCard>
}

@if (importResults.Count > 0)
{
    <FluentCard Style="margin-top: 1rem;">
        <FluentLabel Typo="Typography.Subject">Import Results</FluentLabel>
        <div style="margin-top: 0.5rem;">
            @foreach (var result in importResults)
            {
                <div style="margin-bottom: 0.5rem;">
                    <FluentBadge BackgroundColor="@(result.errors.Count == 0 ? "#4caf50" : "#ff9800")"
                                 Color="white">
                        @result.community
                    </FluentBadge>
                    <span style="margin-left: 0.5rem;">@result.imported item(s) imported</span>
                    @if (result.errors.Count > 0)
                    {
                        <ul style="color: var(--error); margin-top: 0.25rem; font-size: 0.85rem;">
                            @foreach (var error in result.errors)
                            {
                                <li>@error</li>
                            }
                        </ul>
                    }
                </div>
            }
        </div>
    </FluentCard>
}
