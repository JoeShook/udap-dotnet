@page "/credential-schemas"
@using Sigil.Common.Data.Entities

<PageTitle>Sigil - Credential Schemas</PageTitle>

<FluentLabel Typo="Typography.PageTitle">Credential Schemas</FluentLabel>

<FluentCard Style="margin-top: 1rem;">
    <FluentStack Orientation="Orientation.Horizontal" Style="align-items: center; gap: 0.5rem;">
        <FluentLabel Typo="Typography.Subject">Schemas describing the shape of issued credentials</FluentLabel>
        <FluentSpacer />
        <FluentButton Appearance="Appearance.Accent" OnClick="ShowAddDialog"
                      IconStart="@(new Icons.Regular.Size16.Add())">
            New Schema
        </FluentButton>
    </FluentStack>

    <FluentDataGrid Items="@schemas.AsQueryable()" Style="margin-top: 0.5rem;" ResizableColumns="true"
                    GridTemplateColumns="minmax(180px, 1.5fr) minmax(200px, 2fr) 100px minmax(140px, 1fr) 110px 90px auto">
        <PropertyColumn Property="@(s => s.Name)" Title="Name" Sortable="true" IsDefaultSortColumn="true" />
        <PropertyColumn Property="@(s => s.Description)" Title="Description" />
        <PropertyColumn Property="@(s => s.Format)" Title="Format" />
        <PropertyColumn Property="@(s => s.TypeUri)" Title="Type URI" />
        <PropertyColumn Property="@(s => s.DefaultValidityDays)" Title="Validity (days)" />
        <TemplateColumn Title="Preset">
            @if (context.IsPreset)
            {
                <FluentBadge Appearance="Appearance.Accent">preset</FluentBadge>
            }
        </TemplateColumn>
        <TemplateColumn Title="Actions">
            <FluentStack Orientation="Orientation.Horizontal" Wrap="true" Style="gap: 0.25rem;">
                <FluentButton Size="ButtonSize.Small" Appearance="Appearance.Outline"
                              IconStart="@(new Icons.Regular.Size16.Edit())"
                              OnClick="@(() => ShowEditDialog(context))">
                    Edit
                </FluentButton>
                @if (!context.IsPreset)
                {
                    <FluentButton Size="ButtonSize.Small" Appearance="Appearance.Outline"
                                  IconStart="@(new Icons.Regular.Size16.Delete())"
                                  OnClick="@(() => DeleteAsync(context))">
                        Delete
                    </FluentButton>
                }
            </FluentStack>
        </TemplateColumn>
    </FluentDataGrid>
</FluentCard>

<FluentDialog @bind-Hidden="@dialogHidden" Modal="true" TrapFocus="true"
              Style="min-width: 800px; max-height: 85vh; overflow: auto;">
    <FluentDialogHeader>@(isEditing ? "Edit Credential Schema" : "New Credential Schema")</FluentDialogHeader>
    <FluentDialogBody>
        <FluentTextField @bind-Value="editName" Label="Name" Style="width: 100%;"
                         Placeholder="MemberCredential" />
        <FluentTextField @bind-Value="editDescription" Label="Description" Style="width: 100%; margin-top: 0.5rem;"
                         Placeholder="Claims a subject has a named role within an organization." />
        <FluentTextField @bind-Value="editTypeUri" Label="Type URI (optional)" Style="width: 100%; margin-top: 0.5rem;"
                         Placeholder="MemberCredential" />

        <FluentStack Orientation="Orientation.Horizontal" Style="gap: 0.5rem; margin-top: 0.5rem;">
            <FluentSelect TOption="string" @bind-Value="editFormat" Label="Format" Style="width: 150px;">
                @foreach (var f in supportedFormats)
                {
                    <FluentOption Value="@f">@f</FluentOption>
                }
            </FluentSelect>
            <FluentNumberField TValue="int?" @bind-Value="editValidityDays" Label="Default Validity (days)"
                               Style="width: 180px;" />
        </FluentStack>

        <FluentLabel Typo="Typography.Subject" Style="margin-top: 0.75rem;">Claims JSON Schema</FluentLabel>
        <FluentTextArea @bind-Value="editClaimsSchemaJson"
                        Style="width: 100%; min-height: 220px; font-family: monospace; font-size: 12px;"
                        Placeholder="JSON Schema document" />

        @if (!string.IsNullOrEmpty(saveError))
        {
            <FluentMessageBar Intent="MessageIntent.Error" AllowDismiss="false" Style="margin-top: 0.5rem;">
                @saveError
            </FluentMessageBar>
        }
    </FluentDialogBody>
    <FluentDialogFooter>
        <FluentButton Appearance="Appearance.Accent" OnClick="SaveAsync"
                      Disabled="@(string.IsNullOrWhiteSpace(editName))">
            @(isEditing ? "Save" : "Create")
        </FluentButton>
        <FluentButton Appearance="Appearance.Outline" OnClick="@(() => dialogHidden = true)">
            Cancel
        </FluentButton>
    </FluentDialogFooter>
</FluentDialog>
