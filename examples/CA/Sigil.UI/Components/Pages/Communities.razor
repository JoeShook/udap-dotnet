@page "/communities"

<PageTitle>Sigil - Communities</PageTitle>

<FluentLabel Typo="Typography.PageTitle">Communities</FluentLabel>

<FluentCard Style="margin-top: 1rem;">
    <FluentStack Orientation="Orientation.Horizontal" Style="align-items: center; gap: 0.5rem;">
        <FluentLabel Typo="Typography.Subject">PKI Communities</FluentLabel>
        <FluentSpacer />
        <FluentButton Appearance="Appearance.Accent" OnClick="ShowAddDialog"
                      IconStart="@(new Icons.Regular.Size16.Add())">
            Add Community
        </FluentButton>
    </FluentStack>

    <FluentDataGrid Items="@communities.AsQueryable()" Style="margin-top: 0.5rem;" ResizableColumns="true" GridTemplateColumns="minmax(120px, 1fr) minmax(120px, 1.5fr) minmax(200px, 3fr) 80px 80px 80px auto">
        <PropertyColumn Property="@(c => c.Name)" Title="Name" Sortable="true" IsDefaultSortColumn="true" />
        <PropertyColumn Property="@(c => c.Description)" Title="Description" />
        <TemplateColumn Title="Certificate Server Base URLs">
            <div style="white-space: normal; word-break: break-all; line-height: 1.4;">
                @foreach (var url in context.BaseUrls)
                {
                    <div>@url.Url</div>
                }
            </div>
        </TemplateColumn>
        <TemplateColumn Title="Enabled">
            @if (context.Enabled)
            {
                <FluentBadge BackgroundColor="#4caf50" Color="white">Yes</FluentBadge>
            }
            else
            {
                <FluentBadge BackgroundColor="#666" Color="white">No</FluentBadge>
            }
        </TemplateColumn>
        <PropertyColumn Property="@(c => c.RootCaCount)" Title="Root CAs" />
        <PropertyColumn Property="@(c => c.TotalCertCount)" Title="Total Certs" />
        <TemplateColumn Title="Actions">
            <FluentStack Orientation="Orientation.Horizontal" Style="gap: 0.25rem;">
                <FluentButton Size="ButtonSize.Small"
                              Appearance="Appearance.Outline"
                              IconStart="@(new Icons.Regular.Size16.Certificate())"
                              OnClick="@(() => NavigateToExplorer(context.Id))">
                    Explore
                </FluentButton>
                <FluentButton Size="ButtonSize.Small"
                              Appearance="Appearance.Outline"
                              IconStart="@(new Icons.Regular.Size16.Edit())"
                              OnClick="@(() => ShowEditDialog(context))">
                    Edit
                </FluentButton>
                <FluentButton Size="ButtonSize.Small"
                              Appearance="Appearance.Outline"
                              IconStart="@(new Icons.Regular.Size16.Delete())"
                              OnClick="@(() => DeleteCommunityAsync(context))">
                    Delete
                </FluentButton>
            </FluentStack>
        </TemplateColumn>
    </FluentDataGrid>
</FluentCard>

<FluentDialog @bind-Hidden="@addDialogHidden" Modal="true" TrapFocus="true"
              Style="min-width: 600px;">
    <FluentDialogHeader>Add Community</FluentDialogHeader>
    <FluentDialogBody>
        <FluentTextField @bind-Value="newCommunityName" Label="Name" Style="width: 100%;" />
        <FluentTextField @bind-Value="newCommunityDescription" Label="Description" Style="width: 100%; margin-top: 0.5rem;" />
        <FluentLabel Typo="Typography.Subject" Style="margin-top: 0.5rem;">Certificate Server Base URLs</FluentLabel>
        @foreach (var url in newCommunityBaseUrls)
        {
            <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.25rem; margin-top: 0.25rem; padding: 0.5rem; border: 1px solid var(--neutral-stroke-rest); border-radius: 4px;">
                <FluentStack Orientation="Orientation.Horizontal" Style="gap: 0.5rem; align-items: end;">
                    <FluentTextField @bind-Value="url.Value" Label="Base URL" Style="flex: 1;"
                                     Placeholder="http://host.docker.internal:5033" />
                    <FluentButton Appearance="Appearance.Outline" Size="ButtonSize.Small"
                                  IconStart="@(new Icons.Regular.Size16.Delete())"
                                  OnClick="@(() => newCommunityBaseUrls.Remove(url))" />
                </FluentStack>
                <FluentStack Orientation="Orientation.Horizontal" Style="gap: 0.5rem; align-items: end;">
                    <FluentTextField @bind-Value="url.PublishingBasePath" Label="Publishing Path"
                                     Placeholder="../Sigil.Certificate.Server/wwwroot"
                                     Style="flex: 1;" />
                    <FluentButton Appearance="Appearance.Outline" Size="ButtonSize.Small"
                                  IconStart="@(new Icons.Regular.Size16.FolderOpen())"
                                  OnClick="@(() => ShowFolderBrowser(url))"
                                  title="Browse for folder" />
                </FluentStack>
            </FluentStack>
        }
        <FluentButton Appearance="Appearance.Outline" Size="ButtonSize.Small"
                      IconStart="@(new Icons.Regular.Size16.Add())"
                      OnClick="@(() => newCommunityBaseUrls.Add(new BaseUrlEntry()))"
                      Style="margin-top: 0.25rem;">
            Add Base URL
        </FluentButton>
    </FluentDialogBody>
    <FluentDialogFooter>
        <FluentButton Appearance="Appearance.Accent" OnClick="AddCommunityAsync"
                      Disabled="@(string.IsNullOrWhiteSpace(newCommunityName))">
            Create
        </FluentButton>
        <FluentButton Appearance="Appearance.Outline" OnClick="@(() => addDialogHidden = true)">
            Cancel
        </FluentButton>
    </FluentDialogFooter>
</FluentDialog>

<FluentDialog @bind-Hidden="@editDialogHidden" Modal="true" TrapFocus="true"
              Style="min-width: 600px;">
    <FluentDialogHeader>Edit Community</FluentDialogHeader>
    <FluentDialogBody>
        <FluentTextField @bind-Value="editCommunityName" Label="Name" Style="width: 100%;" />
        <FluentTextField @bind-Value="editCommunityDescription" Label="Description" Style="width: 100%; margin-top: 0.5rem;" />
        <FluentLabel Typo="Typography.Subject" Style="margin-top: 0.5rem;">Certificate Server Base URLs</FluentLabel>
        @foreach (var url in editCommunityBaseUrls)
        {
            <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.25rem; margin-top: 0.25rem; padding: 0.5rem; border: 1px solid var(--neutral-stroke-rest); border-radius: 4px;">
                <FluentStack Orientation="Orientation.Horizontal" Style="gap: 0.5rem; align-items: end;">
                    <FluentTextField @bind-Value="url.Value" Label="Base URL" Style="flex: 1;"
                                     Placeholder="http://host.docker.internal:5033" />
                    <FluentButton Appearance="Appearance.Outline" Size="ButtonSize.Small"
                                  IconStart="@(new Icons.Regular.Size16.Delete())"
                                  OnClick="@(() => editCommunityBaseUrls.Remove(url))" />
                </FluentStack>
                <FluentStack Orientation="Orientation.Horizontal" Style="gap: 0.5rem; align-items: end;">
                    <FluentTextField @bind-Value="url.PublishingBasePath" Label="Publishing Path"
                                     Placeholder="../Sigil.Certificate.Server/wwwroot"
                                     Style="flex: 1;" />
                    <FluentButton Appearance="Appearance.Outline" Size="ButtonSize.Small"
                                  IconStart="@(new Icons.Regular.Size16.FolderOpen())"
                                  OnClick="@(() => ShowFolderBrowser(url))"
                                  title="Browse for folder" />
                </FluentStack>
            </FluentStack>
        }
        <FluentButton Appearance="Appearance.Outline" Size="ButtonSize.Small"
                      IconStart="@(new Icons.Regular.Size16.Add())"
                      OnClick="@(() => editCommunityBaseUrls.Add(new BaseUrlEntry()))"
                      Style="margin-top: 0.25rem;">
            Add Base URL
        </FluentButton>
    </FluentDialogBody>
    <FluentDialogFooter>
        <FluentButton Appearance="Appearance.Accent" OnClick="SaveEditAsync"
                      Disabled="@(string.IsNullOrWhiteSpace(editCommunityName))">
            Save
        </FluentButton>
        <FluentButton Appearance="Appearance.Outline" OnClick="@(() => editDialogHidden = true)">
            Cancel
        </FluentButton>
    </FluentDialogFooter>
</FluentDialog>

<FluentDialog @bind-Hidden="@folderBrowserHidden" Modal="true" TrapFocus="true"
              Style="min-width: 600px; max-height: 80vh;">
    <FluentDialogHeader>Select Folder</FluentDialogHeader>
    <FluentDialogBody>
        <FluentStack Orientation="Orientation.Horizontal" Style="gap: 0.5rem; align-items: center; margin-bottom: 0.5rem;">
            <FluentCheckbox @bind-Value="folderBrowserUseRelative" Label="Relative path" />
            <FluentSpacer />
            <FluentLabel Typo="Typography.Body" Style="color: var(--neutral-foreground-hint); font-size: 0.85rem;">
                App root: @appBasePath
            </FluentLabel>
        </FluentStack>
        <FluentTextField Value="@folderBrowserDisplayPath" ReadOnly="true" Label="Selected path"
                         Style="width: 100%; margin-bottom: 0.5rem;" />
        <div style="border: 1px solid var(--neutral-stroke-rest); border-radius: 4px; max-height: 400px; overflow-y: auto;">
            @if (!string.IsNullOrEmpty(folderBrowserCurrentPath) && Directory.GetParent(folderBrowserCurrentPath) != null)
            {
                <div style="padding: 0.4rem 0.75rem; cursor: pointer; display: flex; align-items: center; gap: 0.5rem;"
                     @onclick="FolderBrowserNavigateUp"
                     class="hover-highlight">
                    <FluentIcon Value="@(new Icons.Regular.Size16.ArrowUp())" />
                    <span>..</span>
                </div>
            }
            @foreach (var dir in folderBrowserSubdirectories)
            {
                <div style="padding: 0.4rem 0.75rem; cursor: pointer; display: flex; align-items: center; gap: 0.5rem;
                            @(dir == folderBrowserSelectedSubdir ? "background: var(--accent-fill-rest); color: var(--foreground-on-accent-rest);" : "")"
                     @onclick="@(() => FolderBrowserSelectDir(dir))"
                     @ondblclick="@(() => FolderBrowserNavigateInto(dir))"
                     class="hover-highlight">
                    <FluentIcon Value="@(new Icons.Regular.Size16.Folder())" />
                    <span>@Path.GetFileName(dir)</span>
                </div>
            }
            @if (folderBrowserSubdirectories.Count == 0)
            {
                <div style="padding: 0.75rem; color: var(--neutral-foreground-hint); font-style: italic;">
                    No subdirectories
                </div>
            }
        </div>
    </FluentDialogBody>
    <FluentDialogFooter>
        <FluentButton Appearance="Appearance.Accent" OnClick="FolderBrowserConfirm">
            Select
        </FluentButton>
        <FluentButton Appearance="Appearance.Outline" OnClick="@(() => folderBrowserHidden = true)">
            Cancel
        </FluentButton>
    </FluentDialogFooter>
</FluentDialog>
